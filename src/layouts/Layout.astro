---
import { ViewTransitions } from 'astro:transitions';
import SpeedInsights from "@vercel/speed-insights/astro"
import '../styles/global.css';
import FloatingCTA from '../components/ui/FloatingCTA.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'es' | 'en';
}

const { 
  lang = getLangFromUrl(Astro.url) as 'es' | 'en', 
  title,
  description = useTranslations(lang)('site.descriptionDefault'),
  image = "/assets/logo-final.jpg"
} = Astro.props;

const t = useTranslations(lang);
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://nutrilev.com');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon2.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={t('site.keywords')} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- View Transitions -->
    <ViewTransitions />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | Nutrilev Especializada`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />

    <meta name="generator" content={Astro.generator} />
    
    <!-- Local Business Schema -->
    <script type="application/ld+json" is:inline set:html={`
      {
        "@context": "https://schema.org",
        "@type": "Nutritionist",
        "name": "Nutrilev Especializada",
        "image": "https://nutrilevespecializada.com/assets/logo-final.jpg",
        "url": "https://nutrilevespecializada.com",
        "telephone": "+526143958598",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "C. Presa del Rejón 11306-1, Lomas del Valle",
          "addressLocality": "Chihuahua",
          "addressRegion": "CHIH",
          "postalCode": "31217",
          "addressCountry": "MX"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 28.62717,
          "longitude": -106.0809239
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "18:30"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "08:00",
            "closes": "17:00"
          }
        ],
        "sameAs": [
          "https://www.facebook.com/profile.php?id=100064033451986",
          "https://www.instagram.com/nutrilev_especializada"
        ]
      }
    `}>
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  </head>
  <body class="bg-bg-base text-slate-800 font-['Inter',sans-serif]">
    <slot />
    <FloatingCTA />
    <SpeedInsights />

    <script>
      document.addEventListener('astro:page-load', () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.fade-in-section').forEach(element => {
          observer.observe(element);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 130px;
  }

  @media (min-width: 768px) {
    html {
      scroll-padding-top: 180px;
    }
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', serif;
  }
</style>
