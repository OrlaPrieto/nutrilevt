---
import { Image } from "astro:assets";
import logoImg from "../assets/logo-final.jpg";
import WhatsAppIcon from "./icons/WhatsAppIcon.astro";
import InstagramIcon from "./icons/InstagramIcon.astro";
import FacebookIcon from "./icons/FacebookIcon.astro";
---

<footer id="contact" class="bg-slate-900 text-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-2">
        <a href="/" class="block mb-6">
          <Image
            src={logoImg}
            alt="Nutrilev Logo"
            class="h-32 w-auto object-contain bg-white rounded-lg p-1"
          />
        </a>
        <p class="text-slate-400 max-w-md text-lg leading-relaxed">
          Especialista en nutrición clínica y transformación de hábitos.
          Ubicados en el corazón de la ciudad, listos para acompañarte en tu
          viaje hacia el bienestar.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider text-sm">
          Enlaces
        </h4>
        <ul class="space-y-4 text-slate-400">
          <li>
            <a href="#" class="hover:text-accent transition-colors">Inicio</a>
          </li>
          <li>
            <a href="#about" class="hover:text-accent transition-colors"
              >Sobre mí</a
            >
          </li>
          <li>
            <a href="#services" class="hover:text-accent transition-colors"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#consultation-modes"
              class="hover:text-accent transition-colors">Modalidades</a
            >
          </li>
          <li>
            <a href="#testimonials" class="hover:text-accent transition-colors"
              >Opiniones</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-white mb-6 uppercase tracking-wider text-sm">
          Contacto
        </h4>
        <ul class="space-y-4 text-slate-400">
          <li>nutrilev@outlook.es</li>
          <li>+52 (614) 395-8598</li>
        </ul>
      </div>
    </div>
    <div
      class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 text-sm"
    >
      <p>© 2026 Nutrilev Especializada. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a
          href="https://www.instagram.com/nutrilev_especializada"
          target="_blank"
          class="hover:text-accent transition-colors"
          aria-label="Instagram"
        >
          <InstagramIcon class="w-6 h-6" />
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=100064033451986"
          target="_blank"
          class="hover:text-accent transition-colors"
          aria-label="Facebook"
        >
          <FacebookIcon class="w-6 h-6" />
        </a>
        <a
          href="https://wa.me/526143958598"
          target="_blank"
          class="hover:text-accent transition-colors"
          aria-label="WhatsApp"
        >
          <WhatsAppIcon class="w-6 h-6" />
        </a>
      </div>
    </div>
  </div>
</footer>
