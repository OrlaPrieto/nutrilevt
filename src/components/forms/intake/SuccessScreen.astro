// src/components/forms/intake/SuccessScreen.astro
---

<!-- Success Message -->
<div
    id="success-screen"
    class="hidden absolute inset-0 bg-white flex flex-col items-center justify-center p-12 text-center z-20"
>
    <div
        class="w-24 h-24 bg-pink-50 rounded-full flex items-center justify-center text-4xl mb-6 text-primary animate-bounce"
    >
        ✓
    </div>
    <h3 class="text-3xl font-bold text-slate-900 mb-4">
        ¡Historia Clínica Recibida!
    </h3>
    <p class="text-slate-600 mb-8 max-w-sm">
        Toda tu información ha sido enviada con éxito. El último paso es agendar
        tu cita por WhatsApp.
    </p>
    <a
        id="whatsapp-schedule-btn"
        href="https://wa.me/526143958598?text=Hola%2C%20acabo%20de%20llenar%20mi%20historia%20cl%C3%ADnica%20y%20me%20gustar%C3%ADa%20agendar%20una%20cita."
        target="_blank"
        class="bg-[#25D366] text-white px-8 py-3 rounded-full font-bold shadow-lg hover:scale-105 transition-transform flex items-center justify-center gap-2"
    >
        <span>Agendar Cita por WhatsApp</span>
    </a>
</div>
