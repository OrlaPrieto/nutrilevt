---
// src/components/forms/intake/StepHabits.astro
---

<!-- Step 5: Physical Activity & Work -->
<div class="form-step" data-step="5">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 5 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Actividad y Trabajo
        </h3>
        <p class="text-slate-500 mt-2">Tu movimiento y ocupación.</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-3"
                >Actividad física: ¿Realiza actividad física? *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        "No",
                        "1 vez a la semana",
                        "De lunes a viernes",
                        "De lunes a domingo",
                        "3 veces a la semana",
                    ].map((opt) => (
                        <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:bg-slate-50 cursor-pointer">
                            <input
                                type="radio"
                                name="hace_ejercicio"
                                value={opt}
                                required
                                class="w-4 h-4 text-primary"
                            />
                            <span class="text-sm text-slate-600">{opt}</span>
                        </label>
                    ))
                }
                <div
                    class="flex items-center gap-3 p-2 rounded-xl border border-slate-100 italic"
                >
                    <span class="text-xs text-slate-400"
                        >Si es otra, especifica debajo</span
                    >
                </div>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Actividad física: ¿Qué actividad física se hace? ¿Cuánto tiempo
                cada sesión? ¿Desde hace cuánto tiempo?</label
            >
            <input
                type="text"
                name="ejercicio_detalles"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all"
                placeholder="Ej. Natación, 45 min, 6 meses"
            />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Profesión / Ocupación: ¿A que se dedica?</label
                >
                <textarea
                    name="profesion"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                ></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Profesión / Ocupación: ¿Su actividad es sentado (a), parado
                    (a), caminando, etc.? ¿Cuál es su horario laboral?</label
                >
                <textarea
                    name="tipo_actividad_horario"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                ></textarea>
            </div>
        </div>
    </div>
</div>

<!-- Step 6: Nutritional Habits -->
<div class="form-step" data-step="6">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 6 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Hábitos Nutricionales
        </h3>
        <p class="text-slate-500 mt-2">Día a día con la comida.</p>
    </div>

    <div class="space-y-8">
        <div>
            <label
                class="block text-sm font-semibold text-slate-700 mb-2 italic"
                >Diario de actividades 24 hrs. Coloque por favor la hora en que
                hace sus comidas y que es lo que comió el día de ayer, con
                cantidades, sin omitir bebidas y alimentos. *</label
            >
            <textarea
                name="diario_24h"
                required
                rows="4"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                placeholder="Desayuno (8 am): ... Comida: ... Cena: ..."
            ></textarea>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Tiene estudios de laboratorio (Sangre) recientes (menos de
                    6 meses)? *</label
                >
                <div class="space-y-2">
                    {
                        ["Si", "No", "Hace mas de 6 meses"].map((opt) => (
                            <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                <input
                                    type="radio"
                                    name="laboratorios"
                                    value={opt}
                                    required
                                    class="w-4 h-4 text-primary"
                                />
                                <span class="text-xs text-slate-600">
                                    {opt}
                                </span>
                            </label>
                        ))
                    }
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Cuántas comidas hace al día? *</label
                >
                <div class="space-y-2">
                    {
                        ["1 al dia", "2 al dia", "3 al dia", "5 al dia"].map(
                            (opt) => (
                                <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer transition-all">
                                    <input
                                        type="radio"
                                        name="comidas_dia"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary"
                                    />
                                    <span class="text-xs text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            )
                        )
                    }
                    <div
                        class="flex items-center gap-2 p-1 border-b border-pink-50"
                    >
                        <input
                            type="text"
                            name="comidas_dia_otro"
                            class="w-full bg-transparent text-xs outline-none"
                            placeholder="Otro: Especifique aquí"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
