---
// src/components/forms/intake/StepHabits.astro
---

<!-- Step 5: Physical Activity & Work -->
<div class="form-step" data-step="5">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 5 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Actividad y Trabajo
        </h3>
        <p class="text-slate-500 mt-2">Tu movimiento y ocupación.</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >Actividad física: ¿Realiza actividad física? *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        "No",
                        "1 vez a la semana",
                        "3 veces a la semana",
                        "De lunes a viernes",
                        "De lunes a domingo",
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="hace_ejercicio"
                                value={opt}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label !text-xs">{opt}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Actividad física: ¿Qué actividad física se hace? ¿Cuánto tiempo
                cada sesión? ¿Desde hace cuánto tiempo?</label
            >
            <input
                type="text"
                name="ejercicio_detalles"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all"
                placeholder="Ej. Natación, 45 min, 6 meses"
            />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Profesión / Ocupación: ¿A que se dedica?</label
                >
                <textarea
                    name="profesion"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                ></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Profesión / Ocupación: ¿Su actividad es sentado (a), parado
                    (a), caminando, etc.? ¿Cuál es su horario laboral?</label
                >
                <textarea
                    name="tipo_actividad_horario"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                ></textarea>
            </div>
        </div>
    </div>
</div>

<!-- Step 6: Nutritional Habits -->
<div class="form-step" data-step="6">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 6 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Hábitos Nutricionales
        </h3>
        <p class="text-slate-500 mt-2">Día a día con la comida.</p>
    </div>

    <div class="space-y-8">
        <div class="space-y-6">
            <label
                class="block text-sm font-semibold text-slate-700 mb-2 italic border-b border-primary/20 pb-2"
                >Recordatorio de 24 Horas: Por favor, detalla lo que comió el día de ayer, incluyendo horas y cantidades. *</label
            >
            
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Desayuno</label>
                    <textarea
                        name="diario_desayuno"
                        required
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Hora y detalle..."></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Colación Matutina</label>
                    <textarea
                        name="diario_colacion_mat"
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Hora y detalle (si hubo)..."></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Comida</label>
                    <textarea
                        name="diario_comida"
                        required
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Hora y detalle..."></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Colación Vespertina</label>
                    <textarea
                        name="diario_colacion_vesp"
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Hora y detalle (si hubo)..."></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Cena</label>
                    <textarea
                        name="diario_cena"
                        required
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Hora y detalle..."></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold text-primary mb-1 uppercase tracking-wider">Extras / Bebidas / Picoteo</label>
                    <textarea
                        name="diario_extras"
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Agua, refrescos, dulces..."></textarea>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Tiene estudios de laboratorio (Sangre) recientes (menos de 6 meses)? *</label
                >
                <div class="selection-grid">
                    {
                        ["Si", "No", "Hace mas de 6 meses"].map((opt) => (
                            <label class="selection-card">
                                <input
                                    type="radio"
                                    name="laboratorios"
                                    value={opt}
                                    required
                                />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label">{opt}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Cuántas comidas hace al día? *</label
                >
                <div class="grid grid-cols-2 gap-3">
                    {
                        ["1-2", "3", "4", "5+"].map(
                            (opt) => (
                                <label class="selection-card">
                                    <input
                                        type="radio"
                                        name="comidas_dia"
                                        value={opt}
                                        required
                                    />
                                    <div class="card-content">
                                        <div class="radio-indicator"></div>
                                        <span class="card-label">{opt}</span>
                                    </div>
                                </label>
                            )
                        )
                    }
                    <div class="col-span-2 mt-2">
                        <input
                            type="text"
                            name="comidas_dia_otro"
                            class="w-full px-4 py-2 rounded-xl border border-slate-200 text-xs focus:border-primary outline-none transition-all"
                            placeholder="Otro: Especifique aquí"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
