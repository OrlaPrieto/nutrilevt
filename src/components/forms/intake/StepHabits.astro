---
// src/components/forms/intake/StepHabits.astro
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Step 5: Activity & Work -->
<div class="form-step" data-step="5">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 5 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step5.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step5.subtitle')}</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.physicalActivity')}</label
            >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {
                    [
                        { value: "No", label: t('intake.activity.no') },
                        { value: "1 vez a la semana", label: t('intake.activity.1w') },
                        { value: "3 veces a la semana", label: t('intake.activity.3w') },
                        { value: "De lunes a viernes", label: t('intake.activity.monFri') },
                        { value: "De lunes a domingo", label: t('intake.activity.monSun') },
                    ].map((opt) => (
                        <label class="selection-card h-auto py-3">
                            <input
                                type="radio"
                                name="hace_ejercicio"
                                value={opt.value}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label text-sm font-medium">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label for="ejercicio_detalles" class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.exerciseDetails')}</label
            >
            <textarea
                id="ejercicio_detalles"
                name="ejercicio_detalles"
                rows="2"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all resize-none text-sm"
                placeholder={t('intake.field.exerciseDetailsPlaceholder')}></textarea>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label for="profesion" class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.occupation')}</label
                >
                <input
                    type="text"
                    id="profesion"
                    name="profesion"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                />
            </div>
            <div>
                <label for="tipo_actividad_horario" class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.occupationType')}</label
                >
                <input
                    type="text"
                    id="tipo_actividad_horario"
                    name="tipo_actividad_horario"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                />
            </div>
        </div>
    </div>
</div>

<!-- Step 6: Nutritional Habits -->
<div class="form-step" data-step="6">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 6 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step6.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step6.subtitle')}</p>
    </div>

    <div class="space-y-6">
        <div class="premium-card p-6 bg-slate-50/50 border border-slate-200/50">
            <label class="block text-sm font-bold text-slate-800 mb-4 uppercase tracking-wider"
                >{t('intake.field.recall24h')}</label
            >
            <div class="grid gap-4">
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_desayuno" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.breakfast')}</label>
                    <input type="text" id="diario_desayuno" name="diario_desayuno" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.breakfastPlaceholder')} />
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_colacion_mat" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.morningSnack')}</label>
                    <input type="text" id="diario_colacion_mat" name="diario_colacion_mat" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.morningSnackPlaceholder')} />
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_comida" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.lunch')}</label>
                    <input type="text" id="diario_comida" name="diario_comida" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.lunchPlaceholder')} />
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_colacion_vesp" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.afternoonSnack')}</label>
                    <input type="text" id="diario_colacion_vesp" name="diario_colacion_vesp" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.afternoonSnackPlaceholder')} />
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_cena" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.dinner')}</label>
                    <input type="text" id="diario_cena" name="diario_cena" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.dinnerPlaceholder')} />
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                    <label for="diario_extras" class="text-xs font-bold text-primary sm:w-32 uppercase">{t('intake.meal.extras')}</label>
                    <input type="text" id="diario_extras" name="diario_extras" class="flex-1 px-4 py-2.5 rounded-xl border border-white bg-white shadow-sm focus:border-primary outline-none text-sm" placeholder={t('intake.meal.extrasPlaceholder')} />
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.labTests')}</label
                >
                <div class="grid grid-cols-1 gap-2">
                    {
                        [
                            { value: "Si", label: t('intake.labs.yes') },
                            { value: "No", label: t('intake.labs.no') },
                            { value: "Hace mas de 6 meses", label: t('intake.labs.old') }
                        ].map((opt) => (
                            <label class="selection-card h-auto py-3 px-4">
                                <input type="radio" name="laboratorios" value={opt.value} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label text-sm">{opt.label}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.mealsPerDay')}</label
                >
                <div class="flex flex-wrap gap-2">
                    {
                        ["1", "2", "3", "4", "5", "Otro"].map((opt) => (
                            <label class="flex-1 min-w-[60px]">
                                <input type="radio" name="comidas_dia" value={opt} class="peer hidden" required />
                                <div class="peer-checked:bg-primary peer-checked:text-white border border-slate-200 rounded-xl py-3 text-center text-sm font-bold text-slate-600 transition-all cursor-pointer hover:border-primary/50">
                                    {opt}
                                </div>
                            </label>
                        ))
                    }
                </div>
                <input type="text" name="comidas_dia_otro" class="mt-3 w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-xs hidden-until-needed" placeholder={t('intake.mealsPerDay.placeholder')} />
            </div>
        </div>
    </div>
</div>
