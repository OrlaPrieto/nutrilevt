---
// src/components/forms/intake/StepHealthBackground.astro
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Step 3: Medical Background -->
<div class="form-step" data-step="3">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 3 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step3.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step3.subtitle')}</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.pathological')}</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        { value: "Diarrea", label: t('intake.pathological.diarrhea') },
                        { value: "Estreñimiento", label: t('intake.pathological.constipation') },
                        { value: "Gastritis", label: t('intake.pathological.gastritis') },
                        { value: "Úlceras", label: t('intake.pathological.ulcers') },
                        { value: "Nauseas", label: t('intake.pathological.nausea') },
                        { value: "Pirosis", label: t('intake.pathological.pyrosis') },
                        { value: "Vomito", label: t('intake.pathological.vomiting') },
                        { value: "Colitis", label: t('intake.pathological.colitis') },
                        { value: "Dentadura", label: t('intake.pathological.denture') },
                        { value: "Otros", label: t('intake.pathological.others') },
                        { value: "Ninguno", label: t('intake.pathological.none') },
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="antecedentes_patologicos"
                                value={opt.value}
                            />
                            <div class="card-content">
                                <div class="checkbox-indicator"></div>
                                <span class="card-label !text-xs">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.medicationsCheck')}</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                {
                    [
                        { value: "Laxantes", label: t('intake.meds.laxatives') },
                        { value: "Diuréticos", label: t('intake.meds.diuretics') },
                        { value: "Antiácidos", label: t('intake.meds.antacids') },
                        { value: "Analgésicos", label: t('intake.meds.analgesics') },
                        { value: "Ninguno", label: t('intake.meds.none') },
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="toma_medicamentos"
                                value={opt.value}
                            />
                            <div class="card-content">
                                <div class="checkbox-indicator"></div>
                                <span class="card-label !text-xs">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.diseases')}</label
                >
                <input
                    type="text"
                    name="enfermedades"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder={t('intake.field.diseasesPlaceholder')}
                />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.treatment')}</label
                >
                <input
                    type="text"
                    name="medicamentos"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder={t('intake.field.treatmentPlaceholder')}
                />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.surgeries')}</label
                >
                <textarea
                    name="cirugias"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none text-sm"
                ></textarea>
            </div>
        </div>
    </div>
</div>

<!-- Step 4: Family & Habits -->
<div class="form-step" data-step="4">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 4 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step4.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step4.subtitle')}</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.familyHistory')}</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        { value: "Diabetes", label: t('intake.family.diabetes') },
                        { value: "Hipertensión", label: t('intake.family.hypertension') },
                        { value: "Cáncer", label: t('intake.family.cancer') },
                        { value: "Cardiopatías", label: t('intake.family.heart') },
                        { value: "Obesidad", label: t('intake.family.obesity') },
                        { value: "Colesterol", label: t('intake.family.cholesterol') },
                        { value: "Triglicéridos", label: t('intake.family.triglycerides') },
                        { value: "Otra", label: t('intake.family.other') },
                        { value: "Ninguna", label: t('intake.family.none') },
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="antecedentes_familiares"
                                value={opt.value}
                            />
                            <div class="card-content">
                                <div class="checkbox-indicator"></div>
                                <span class="card-label !text-xs">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.alcohol')}</label
                >
                <div class="space-y-2">
                    {
                        [
                            { value: "No", label: t('intake.habits.no') },
                            { value: "Social", label: t('intake.habits.social') },
                            { value: "Frecuente", label: t('intake.habits.frequent') },
                            { value: "Muy frecuente", label: t('intake.habits.veryFrequent') }
                        ].map((opt) => (
                            <label class="selection-card h-auto py-3">
                                <input type="radio" name="alcohol" value={opt.value} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label">{opt.label}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.smoking')}</label
                >
                <div class="grid grid-cols-2 gap-3">
                    {
                         [
                            { value: "No", label: t('intake.habits.no') },
                            { value: "Social", label: t('intake.habits.social') },
                            { value: "Frecuente", label: t('intake.habits.frequent') },
                            { value: "Muy frecuente", label: t('intake.habits.veryFrequent') }
                        ].map((opt) => (
                        <label class="selection-card h-auto py-3">
                            <input type="radio" name="tabaco" value={opt.value} required />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label !text-[10px]">{opt.label}</span>
                            </div>
                        </label>
                    ))
                    }
                </div>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.sleep')}</label
            >
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {
                    [
                        { value: "Menos de 5-6h", label: t('intake.sleep.less6') },
                        { value: "7 a 8 horas", label: t('intake.sleep.7to8') },
                        { value: "Más de 8-10h", label: t('intake.sleep.more8') }
                    ].map((opt) => (
                        <label class="selection-card h-auto py-4">
                            <input type="radio" name="sueno" value={opt.value} required />
                            <div class="card-content text-center">
                                <div class="radio-indicator mx-auto mb-2"></div>
                                <span class="card-label block w-full">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>
    </div>
</div>
