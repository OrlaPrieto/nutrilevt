---
// src/components/forms/intake/StepHealthBackground.astro
---

<!-- Step 3: Medical Background -->
<div class="form-step" data-step="3">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 3 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Antecedentes Médicos
        </h3>
        <p class="text-slate-500 mt-2">Información clínica importante.</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >Antecedentes personales patológicos: Seleccionar si presenta
                alguna de las siguientes condiciones. *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                {
                    [
                        "Diarrea",
                        "Estreñimiento",
                        "Gastritis",
                        "Úlceras",
                        "Nauseas",
                        "Pirosis",
                        "Vomito",
                        "Colitis",
                        "Dentadura",
                        "Otros",
                        "Ninguno",
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="antecedentes_patologicos"
                                value={opt}
                                required
                            />
                            <div class="card-content">
                                <div class="checkbox-indicator">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="4"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </div>
                                <span class="card-label !text-[10px] sm:!text-[11px]">
                                    {opt}
                                </span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >¿Toma alguno de los siguientes? *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
                {
                    [
                        "Laxantes",
                        "Diuréticos",
                        "Antiácidos",
                        "Analgésicos",
                        "Ninguno",
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="toma_medicamentos"
                                value={opt}
                                required
                            />
                            <div class="card-content !p-2">
                                <div class="checkbox-indicator">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                </div>
                                <span class="card-label !text-[10px] sm:!text-[11px]">{opt}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Enfermedades diagnosticada:</label
                >
                <textarea
                    name="enfermedades"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Detalla si aplica..."></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >¿Tratamiento farmacológico? (Medicamentos)</label
                >
                <textarea
                    name="medicamentos"
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Nombre y dosis si los conoces..."></textarea>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >¿Le han practicado alguna cirugía? ¿Cuál? ¿Hace cuánto tiempo?
                *</label
            >
            <textarea
                name="cirugias"
                required
                rows="2"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
            ></textarea>
        </div>
    </div>
</div>

<!-- Step 4: Family & Lifestyle -->
<div class="form-step" data-step="4">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 4 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">
            Familia y Hábitos
        </h3>
        <p class="text-slate-500 mt-2">Entorno y rutinas diarias.</p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >¿Alguien de tu familia presenta alguna enfermedad? (Madre,
                padre, hermanos, tios) *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                {
                    [
                        "Diabetes",
                        "Hipertensión",
                        "Cáncer",
                        "Cardiopatías",
                        "Obesidad",
                        "Colesterol",
                        "Triglicéridos",
                        "Otra",
                        "Ninguna",
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="checkbox"
                                name="antecedentes_familiares"
                                value={opt}
                                required
                            />
                            <div class="card-content !p-2">
                                <div class="checkbox-indicator">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="4"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </div>
                                <span class="card-label !text-[10px] sm:!text-[11px]">
                                    {opt}
                                </span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Bebidas alcohólicas? *</label
                >
                <div class="selection-grid">
                    {
                        ["No", "Social", "Frecuente", "Muy frecuente"].map(
                            (opt) => (
                                <label class="selection-card">
                                    <input
                                        type="radio"
                                        name="alcohol"
                                        value={opt}
                                        required
                                    />
                                    <div class="card-content">
                                        <div class="radio-indicator" />
                                        <span class="card-label">{opt}</span>
                                    </div>
                                </label>
                            )
                        )
                    }
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Cigarros? *</label
                >
                <div class="selection-grid">
                    {
                        ["No", "Social", "Frecuente", "Muy frecuente"].map(
                            (opt) => (
                                <label class="selection-card">
                                    <input
                                        type="radio"
                                        name="tabaco"
                                        value={opt}
                                        required
                                    />
                                    <div class="card-content">
                                        <div class="radio-indicator" />
                                        <span class="card-label">{opt}</span>
                                    </div>
                                </label>
                            )
                        )
                    }
                </div>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >Horas de sueño al día: *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    ["Menos de 5-6h", "7 a 8 horas", "Más de 8-10h"].map(
                        (opt) => (
                            <label class="selection-card">
                                <input
                                    type="radio"
                                    name="sueno"
                                    value={opt}
                                    required
                                />
                                <div class="card-content">
                                    <div class="radio-indicator" />
                                    <span class="card-label">{opt}</span>
                                </div>
                            </label>
                        )
                    )
                }
            </div>
        </div>
    </div>
</div>
