---
// src/components/forms/intake/StepPersonalData.astro
---

<!-- Step 1: Personal Data Part 1 -->
<div class="form-step active" data-step="1">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 1 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">Datos Personales</h3>
        <p class="text-slate-500 mt-2">Comencemos con tu información básica.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Correo electrónico *</label
            >
            <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="tu@email.com"
            />
        </div>
        <div class="relative group">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Fecha de hoy *</label
            >
            <div class="relative">
                <input
                    type="text"
                    id="fecha_hoy"
                    name="fecha_hoy"
                    required
                    readonly
                    class="w-full px-4 py-3 pl-11 rounded-xl border border-slate-200 bg-slate-50 cursor-pointer outline-none transition-all modern-date-input"
                    placeholder="Seleccionar fecha"
                />
                <div
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Nombre completo: *</label
            >
            <input
                type="text"
                name="nombre"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="Nombre Apellido"
            />
        </div>
        <div class="relative group">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Fecha de nacimiento: *</label
            >
            <div class="relative">
                <input
                    type="text"
                    id="fecha_nacimiento"
                    name="fecha_nacimiento"
                    required
                    class="w-full px-4 py-3 pl-11 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all modern-date-input"
                    placeholder="Selecciona tu fecha"
                />
                <div
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors pointer-events-none"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Edad: *</label
            >
            <input
                type="number"
                id="edad"
                name="edad"
                required
                readonly
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 cursor-not-allowed outline-none transition-all"
                placeholder="Se calcula automáticamente"
            />
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Dirección</label
            >
            <input
                type="text"
                name="direccion"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="Calle, Número, Colonia"
            />
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Teléfono: *</label
            >
            <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="(555)-5555555"
            />
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Estatura: *</label
            >
            <input
                type="text"
                id="estatura"
                name="estatura"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="1.90"
            />
        </div>
    </div>
</div>

<!-- Step 2: Personal Data Part 2 -->
<div class="form-step" data-step="2">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 2 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">Perfil y Motivo</h3>
        <p class="text-slate-500 mt-2">
            Cuéntanos más sobre ti y por qué vienes.
        </p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >Género *</label
            >
            <div class="grid grid-cols-2 gap-4">
                {
                    [
                        "Femenino",
                        "Masculino",
                        "No binario",
                        "Prefiero no decirlo",
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="genero"
                                value={opt}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label">{opt}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >Estado Civil *</label
            >
            <div class="grid grid-cols-3 gap-4">
                {
                    ["Soltero", "Casado", "Otro"].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="estado_civil"
                                value={opt}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label">{opt}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Peso habitual (kg):</label
                >
                <input
                    type="number"
                    step="0.1"
                    name="peso_habitual"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder="Ej: 75"
                />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Peso meta (kg):</label
                >
                <input
                    type="number"
                    step="0.1"
                    name="peso_meta"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder="Ej: 70"
                />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >¿Has tenido cambios de peso significativos recientemente? ¿Por qué?</label
                >
                <input
                    type="text"
                    name="cambios_peso_detalle"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder="Ej: Subí 5kg por estrés hace 3 meses..."
                />
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >Motivos de consulta y metas principales *</label
            >
            <textarea
                name="motivos_consulta"
                required
                rows="3"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
                placeholder="¿Qué esperas lograr con este plan alimenticio?"></textarea>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >¿De parte de quién tiene recomendaciones sobre mis servicios? *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        "Amigo/a",
                        "Familiar",
                        "Facebook",
                        "Instagram",
                        "Google",
                        "Página Nutrilev",
                        "Otro"
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="recomendacion_fuente"
                                value={opt}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label !text-[10px] sm:!text-xs">{opt}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <!-- Conditional Female Health Section -->
        <div id="female-health-section" class="hidden premium-card bg-pink-50/30 p-6 rounded-2xl border border-pink-100/50">
            <label class="block text-sm font-bold text-primary mb-3 uppercase tracking-wider"
                >Salud Femenina (Opcional)</label
            >
            <p class="text-xs text-slate-500 mb-4 italic">Esta información nos ayuda a entender cambios metabólicos por ciclo menstrual.</p>
            <textarea
                name="salud_femenina_ciclo"
                rows="2"
                class="w-full px-4 py-3 rounded-xl border border-white bg-white/50 focus:border-primary focus:bg-white outline-none transition-all resize-none text-sm"
                placeholder="¿Tu ciclo es regular? ¿Padeces inflamación o antojos fuertes antes del periodo?"></textarea>
        </div>
    </div>
</div>
