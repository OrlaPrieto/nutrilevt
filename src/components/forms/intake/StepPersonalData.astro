---
// src/components/forms/intake/StepPersonalData.astro
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Step 1: Personal Data Part 1 -->
<div class="form-step active" data-step="1">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 1 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step1.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step1.subtitle')}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.email')}</label
            >
            <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder={t('intake.field.emailPlaceholder')}
            />
        </div>
        <div class="relative group">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.today')}</label
            >
            <div class="relative">
                <input
                    type="text"
                    id="fecha_hoy"
                    name="fecha_hoy"
                    required
                    readonly
                    class="w-full px-4 py-3.5 pl-12 rounded-2xl border border-slate-200 bg-slate-50 shadow-sm cursor-pointer outline-none transition-all modern-date-input hover:border-primary/50 focus:border-primary focus:ring-4 focus:ring-primary/10"
                    placeholder={t('intake.field.todayPlaceholder')}
                />
                <div
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none group-focus-within:text-primary transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.name')}</label
            >
            <input
                type="text"
                name="nombre"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder={t('intake.field.namePlaceholder')}
            />
        </div>
        <div class="relative group">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.birth')}</label
            >
            <div class="relative">
                <input
                    type="text"
                    id="fecha_nacimiento"
                    name="fecha_nacimiento"
                    required
                    class="w-full px-4 py-3.5 pl-12 rounded-2xl border border-slate-200 shadow-sm focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all modern-date-input hover:border-primary/30"
                    placeholder={t('intake.field.birthPlaceholder')}
                />
                <div
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors pointer-events-none"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.age')}</label
            >
            <input
                type="number"
                id="edad"
                name="edad"
                required
                readonly
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 cursor-not-allowed outline-none transition-all"
                placeholder={t('intake.field.agePlaceholder')}
            />
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.address')}</label
            >
            <input
                type="text"
                name="direccion"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder={t('intake.field.addressPlaceholder')}
            />
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.phone')}</label
            >
            <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder={t('intake.field.phonePlaceholder')}
            />
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.stature')}</label
            >
            <input
                type="text"
                inputmode="decimal"
                id="estatura"
                name="estatura"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder={t('intake.field.staturePlaceholder')}
            />
        </div>
    </div>
</div>

<!-- Step 2: Personal Data Part 2 -->
<div class="form-step" data-step="2">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 2 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step2.title')}</h3>
        <p class="text-slate-500 mt-2">
            {t('intake.step2.subtitle')}
        </p>
    </div>

    <div class="space-y-8">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.gender')}</label
            >
            <div class="grid grid-cols-2 gap-4">
                {
                    [
                        { value: "Femenino", label: t('intake.gender.female') },
                        { value: "Masculino", label: t('intake.gender.male') },
                        { value: "No binario", label: t('intake.gender.nonbinary') },
                        { value: "Prefiero no decirlo", label: t('intake.gender.nodisclose') },
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="genero"
                                value={opt.value}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.civil')}</label
            >
            <div class="grid grid-cols-3 gap-4">
                {
                    [
                        { value: "Soltero", label: t('intake.civil.single') },
                        { value: "Casado", label: t('intake.civil.married') },
                        { value: "Otro", label: t('intake.civil.other') }
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="estado_civil"
                                value={opt.value}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.usualWeight')}</label
                >
                <input
                    type="number"
                    step="0.1"
                    name="peso_habitual"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder="Ej: 75"
                />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.targetWeight')}</label
                >
                <input
                    type="number"
                    step="0.1"
                    name="peso_meta"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder="Ej: 70"
                />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.weightChanges')}</label
                >
                <input
                    type="text"
                    name="cambios_peso_detalle"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none transition-all"
                    placeholder={t('intake.field.weightChangesPlaceholder')}
                />
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"
                >{t('intake.field.motives')}</label
            >
            <textarea
                name="motivos_consulta"
                required
                rows="3"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
                placeholder={t('intake.field.motivesPlaceholder')}></textarea>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >{t('intake.field.referral')}</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {
                    [
                        { value: "Amigo/a", label: t('intake.referral.friend') },
                        { value: "Familiar", label: t('intake.referral.family') },
                        { value: "Facebook", label: t('intake.referral.facebook') },
                        { value: "Instagram", label: t('intake.referral.instagram') },
                        { value: "Google", label: t('intake.referral.google') },
                        { value: "Página Nutrilev", label: t('intake.referral.web') },
                        { value: "Otro", label: t('intake.referral.other') }
                    ].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="recomendacion_fuente"
                                value={opt.value}
                                required
                            />
                            <div class="card-content">
                                <div class="radio-indicator"></div>
                                <span class="card-label !text-[10px] sm:!text-xs">{opt.label}</span>
                            </div>
                        </label>
                    ))
                }
            </div>
        </div>

        <!-- Conditional Female Health Section -->
        <div id="female-health-section" class="hidden premium-card bg-pink-50/30 p-6 rounded-2xl border border-pink-100/50">
            <label class="block text-sm font-bold text-primary mb-3 uppercase tracking-wider"
                >{t('intake.field.femaleHealth')}</label
            >
            <p class="text-xs text-slate-500 mb-4 italic">{t('intake.field.femaleHealthDesc')}</p>
            <textarea
                name="salud_femenina_ciclo"
                rows="2"
                class="w-full px-4 py-3 rounded-xl border border-white bg-white/50 focus:border-primary focus:bg-white outline-none transition-all resize-none text-sm"
                placeholder={t('intake.field.femaleHealthPlaceholder')}></textarea>
        </div>
    </div>
</div>
