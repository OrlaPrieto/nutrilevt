---
// src/components/forms/intake/StepFinalDetails.astro
---

<div class="form-step" data-step="7">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 7 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">Detalles Finales</h3>
        <p class="text-slate-500 mt-2">Última información nutricional.</p>
    </div>

    <div class="space-y-8">
        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Cuántas veces a la semana se come comida comprada? *</label
                >
                <div class="space-y-2">
                    {
                        ["1", "2", "3", "5", "Ninguna"].map((opt) => (
                            <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                <input
                                    type="radio"
                                    name="comida_comprada"
                                    value={opt}
                                    required
                                    class="w-4 h-4 text-primary"
                                />
                                <span class="text-xs text-slate-600">
                                    {opt}
                                </span>
                            </label>
                        ))
                    }
                    <div
                        class="flex items-center gap-2 p-1 border-b border-pink-50"
                    >
                        <input
                            type="text"
                            name="comida_comprada_otro"
                            class="w-full bg-transparent text-xs outline-none"
                            placeholder="Otros: Especifique aquí"
                        />
                    </div>
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Quién prepara sus alimentos? *</label
                >
                <div class="space-y-2">
                    {
                        [
                            "Yo",
                            "Espos@",
                            "Madre",
                            "Padre",
                            "Comida comprada",
                        ].map((opt) => (
                            <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                <input
                                    type="radio"
                                    name="quien_cocina"
                                    value={opt}
                                    required
                                    class="w-4 h-4 text-primary"
                                />
                                <span class="text-xs text-slate-600">
                                    {opt}
                                </span>
                            </label>
                        ))
                    }
                    <div
                        class="flex items-center gap-2 p-1 border-b border-pink-50"
                    >
                        <input
                            type="text"
                            name="quien_cocina_otro"
                            class="w-full bg-transparent text-xs outline-none"
                            placeholder="Otros: Especifique aquí"
                        />
                    </div>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Alimentos preferidos: *</label
                >
                <textarea
                    name="alimentos_preferidos"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Los que no pueden faltar..."></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Alimentos que no le agradan: *</label
                >
                <textarea
                    name="alimentos_no_agradan"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Por malestar o gusto propio..."></textarea>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Toma algún suplemento o complemento? *</label
                >
                <div class="flex gap-4">
                    {
                        ["Si", "No"].map((opt) => (
                            <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-primary/20 cursor-pointer transition-all flex-1 text-center">
                                <input
                                    type="radio"
                                    name="suplementos_si_no"
                                    value={opt}
                                    required
                                    class="w-4 h-4 text-primary"
                                />
                                <span class="text-sm text-slate-600">
                                    {opt}
                                </span>
                            </label>
                        ))
                    }
                </div>
                <textarea
                    name="suplementos_cuales"
                    rows="2"
                    class="mt-4 w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="¿Cuáles suplementos?"></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-3"
                    >¿Ha llevado alguna dieta especial? *</label
                >
                <div class="grid grid-cols-2 gap-2">
                    {
                        ["Si", "No", "Con Otro nutriòlogo", "Internet"].map(
                            (opt) => (
                                <label class="flex items-center gap-2 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                    <input
                                        type="radio"
                                        name="dieta_especial"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary"
                                    />
                                    <span class="text-xs text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            )
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</div>
