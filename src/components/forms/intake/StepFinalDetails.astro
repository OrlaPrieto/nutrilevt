---
// src/components/forms/intake/StepFinalDetails.astro
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Step 7: Final Details -->
<div class="form-step" data-step="7">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >{t('intake.step')} 7 {t('intake.of')} 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">{t('intake.step7.title')}</h3>
        <p class="text-slate-500 mt-2">{t('intake.step7.subtitle')}</p>
    </div>

    <div class="space-y-8">
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.preparesMeals')}</label
                >
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    {
                        [
                            { value: "Yo", label: t('intake.prepares.me') },
                            { value: "Familia", label: t('intake.prepares.family') },
                            { value: "Restaurante", label: t('intake.prepares.restaurant') },
                            { value: "Otro", label: t('intake.prepares.other') }
                        ].map((opt) => (
                            <label class="selection-card h-auto py-3 px-4">
                                <input type="radio" name="quien_cocina" value={opt.value} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label text-sm">{opt.label}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
                <input type="text" name="quien_cocina_otro" class="mt-3 w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-xs hidden-until-needed" placeholder={t('intake.mealsPerDay.placeholder')} />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.boughtFood')}</label
                >
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    {
                        ["1", "2", "3", "Más"].map((opt) => (
                            <label class="selection-card h-auto py-3 px-4">
                                <input type="radio" name="comida_comprada" value={opt} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label text-sm">{opt}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
                <input type="text" name="comida_comprada_otro" class="mt-3 w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-xs hidden-until-needed" placeholder={t('intake.field.boughtFoodPlaceholder')} />
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.appetite')}</label
                >
                <div class="grid grid-cols-2 gap-3">
                    {
                        [
                            { value: "Bueno", label: t('intake.appetite.good') },
                            { value: "Regular", label: t('intake.appetite.fair') },
                            { value: "Malo", label: t('intake.appetite.bad') }
                        ].map((opt) => (
                            <label class="selection-card h-auto py-3">
                                <input type="radio" name="apetito_calidad" value={opt.value} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label text-sm">{opt.label}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.anxietyTime')}</label
                >
                <select name="anclaje_ansiedad_momento" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm transition-all" required>
                    <option value="" disabled selected>{t('intake.anxiety.select')}</option>
                    <option value="Mañana">{t('intake.anxiety.morning')}</option>
                    <option value="Tarde">{t('intake.anxiety.afternoon')}</option>
                    <option value="Noche">{t('intake.anxiety.night')}</option>
                    <option value="Todo el día">{t('intake.anxiety.allDay')}</option>
                    <option value="Ninguno">{t('intake.anxiety.none')}</option>
                </select>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.preferredFoods')}</label
                >
                <input type="text" name="alimentos_preferidos" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm" placeholder={t('intake.field.preferredFoodsPlaceholder')} />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.dislikedFoods')}</label
                >
                <input type="text" name="alimentos_no_agradan" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm" placeholder={t('intake.field.dislikedFoodsPlaceholder')} />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.foodAllergies')}</label
                >
                <input type="text" name="alergias_alimentarias" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm" placeholder={t('intake.field.foodAllergiesPlaceholder')} />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >{t('intake.field.pastDiets')}</label
                >
                <input type="text" name="dieta_especial" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm" placeholder={t('intake.field.weightChangesPlaceholder')} />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >{t('intake.field.supplements')}</label
                >
                <div class="flex gap-4 mb-3">
                    {
                        [
                            { value: "Si", label: t('intake.labs.yes') },
                            { value: "No", label: t('intake.labs.no') }
                        ].map((opt) => (
                            <label class="selection-card h-auto py-3 px-8">
                                <input type="radio" name="suplementos_si_no" value={opt.value} required />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label text-sm">{opt.label}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
                <div id="supplements-details-container" class="hidden">
                    <input type="text" name="suplementos_cuales" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary outline-none text-sm" placeholder={t('intake.field.supplementsPlaceholder')} />
                </div>
            </div>
        </div>

        <div class="premium-card p-6 bg-primary/5 border border-primary/10 rounded-2xl">
            <h4 class="text-sm font-bold text-primary mb-2 uppercase tracking-tight">{t('intake.field.privacy')}</h4>
            <p class="text-[10px] leading-relaxed text-slate-500 mb-4 italic">
                {t('intake.field.privacyDesc')}
            </p>
            <label class="flex items-center gap-3 cursor-pointer group">
                <input type="checkbox" name="privacidad_acepto" required class="w-5 h-5 rounded border-slate-300 text-primary focus:ring-primary transition-all" />
                <span class="text-xs font-semibold text-slate-700 group-hover:text-primary transition-colors">
                    {t('intake.field.privacyCheck')}
                </span>
            </label>
        </div>
    </div>
</div>
