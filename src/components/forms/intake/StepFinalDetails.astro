---
// src/components/forms/intake/StepFinalDetails.astro
---

<div class="form-step" data-step="7">
    <div class="text-center mb-10">
        <span class="text-primary font-bold text-sm uppercase tracking-wider"
            >Paso 7 de 7</span
        >
        <h3 class="text-3xl font-bold text-slate-900 mt-2">Detalles Finales</h3>
        <p class="text-slate-500 mt-2">Última información nutricional.</p>
    </div>

    <div class="space-y-8">
        <div class="premium-card bg-slate-50/50 p-6 rounded-2xl border border-slate-100/50">
            <label class="block text-sm font-semibold text-slate-700 mb-4"
                >¿Cuántas veces a la semana se consume comida comprada? *</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
                {
                    ["1", "2", "3", "5+", "Ninguna"].map((opt) => (
                        <label class="selection-card">
                            <input
                                type="radio"
                                name="comida_comprada"
                                value={opt}
                                required
                            />
                            <div class="card-content !p-2">
                                <div class="radio-indicator"></div>
                                <span class="card-label">{opt}</span>
                            </div>
                        </label>
                    ))
                }
                <div class="col-span-2 sm:col-span-5 mt-2">
                    <input
                        type="text"
                        name="comida_comprada_otro"
                        class="w-full px-4 py-3 rounded-xl border border-white bg-white/70 focus:border-primary focus:bg-white outline-none transition-all text-xs"
                        placeholder="Otros (ej. fines de semana)..."
                    />
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Alimentos preferidos: *</label
                >
                <textarea
                    name="alimentos_preferidos"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Los que no pueden faltar..."></textarea>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Alimentos que no le agradan: *</label
                >
                <textarea
                    name="alimentos_no_agradan"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Por malestar o gusto propio..."></textarea>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2"
                    >Alergias o intolerancias alimentarias: *</label
                >
                <textarea
                    name="alergias_alimentarias"
                    required
                    rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    placeholder="Especificar alimentos y tipo de reacción..."></textarea>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Ha llevado alguna dieta especial anteriormente? *</label
                >
                <div class="grid grid-cols-2 gap-3">
                    {
                        ["Si", "No"].map((opt) => (
                            <label class="selection-card">
                                <input
                                    type="radio"
                                    name="dieta_especial"
                                    value={opt}
                                    required
                                />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label">{opt}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Toma algún suplemento o complemento alimenticio? *</label
                >
                <div class="grid grid-cols-2 gap-3">
                    {
                        ["Si", "No"].map((opt) => (
                            <label class="selection-card">
                                <input
                                    type="radio"
                                    name="suplementos_si_no"
                                    value={opt}
                                    required
                                />
                                <div class="card-content">
                                    <div class="radio-indicator"></div>
                                    <span class="card-label">{opt}</span>
                                </div>
                            </label>
                        ))
                    }
                </div>
                <div id="supplements-details-container" class="hidden animate-fade-in mt-4">
                    <textarea
                        name="suplementos_cuales"
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        placeholder="Ej: Multivitamínico, Omega 3, Proteína..."></textarea>
                </div>
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-4"
                    >¿Quién prepara sus alimentos? *</label
                >
                <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
                    {
                        ["Yo", "Espos@", "Madre", "Padre", "Comida comprada"].map(
                            (opt) => (
                                <label class="selection-card">
                                    <input
                                        type="radio"
                                        name="quien_cocina"
                                        value={opt}
                                        required
                                    />
                                    <div class="card-content !p-2">
                                        <div class="radio-indicator"></div>
                                        <span class="card-label !text-[10px] sm:!text-xs">{opt}</span>
                                    </div>
                                </label>
                            )
                        )
                    }
                    <div class="col-span-2 sm:col-span-5 mt-2">
                        <input
                            type="text"
                            name="quien_cocina_otro"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-xs focus:border-primary outline-none transition-all"
                            placeholder="Otros: Especifique aquí"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
