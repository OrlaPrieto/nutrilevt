---
// BeforeAfter.astro
// Sección de resultados y transformaciones con InBody data

const results = [
  {
    initials: "MR",
    color: "#a5c4d4",
    name: "María R.",
    age: "34 años",
    service: "Control de Peso + Psiconutrición",
    duration: "4 meses",
    before: {
      weight: "82 kg",
      fat: "38%",
      muscle: "44 kg",
      visceral: "Nivel 9",
    },
    after: {
      weight: "68 kg",
      fat: "24%",
      muscle: "47 kg",
      visceral: "Nivel 4",
    },
    changes: [
      "-14 kg de peso",
      "-14% grasa corporal",
      "+3 kg músculo",
      "Grasa visceral normalizada",
    ],
    quote: "Por primera vez en años, disfruto comer sin culpa.",
  },
  {
    initials: "JP",
    color: "#FFD1DC",
    name: "Jorge P.",
    age: "41 años",
    service: "Nutrición Deportiva",
    duration: "3 meses",
    before: {
      weight: "78 kg",
      fat: "22%",
      muscle: "58 kg",
      visceral: "Nivel 7",
    },
    after: {
      weight: "81 kg",
      fat: "14%",
      muscle: "66 kg",
      visceral: "Nivel 3",
    },
    changes: [
      "+3 kg (recomposición)",
      "-8% grasa corporal",
      "+8 kg músculo",
      "Rendimiento deportivo ↑",
    ],
    quote:
      "El InBody me mostró que no se trata del peso, sino de la composición.",
  },
  {
    initials: "LC",
    color: "#d4a5c9",
    name: "Laura C.",
    age: "28 años",
    service: "Salud Hormonal (SOP)",
    duration: "5 meses",
    before: {
      weight: "74 kg",
      fat: "35%",
      muscle: "45 kg",
      visceral: "Nivel 8",
    },
    after: {
      weight: "63 kg",
      fat: "22%",
      muscle: "47 kg",
      visceral: "Nivel 3",
    },
    changes: [
      "-11 kg de peso",
      "Ciclos menstruales regulares",
      "-13% grasa corporal",
      "Resistencia a insulina revertida",
    ],
    quote:
      "Mi SOP mejoró muchísimo. Nunca pensé que la nutrición fuera tan clave.",
  },
];
---

<section id="results" class="results-section">
  <div class="results-container">
    <div class="results-header">
      <span class="results-eyebrow">Resultados reales</span>
      <h2 class="results-title">Transformaciones con InBody</h2>
      <p class="results-subtitle">
        Más allá de la báscula. Así es como el análisis de composición corporal
        revela el verdadero progreso de nuestros pacientes.
      </p>
      <p class="results-disclaimer">
        * Resultados individuales. Los datos son representativos y han sido
        modificados para proteger la privacidad de los pacientes.
      </p>
    </div>

    <div class="results-grid">
      {
        results.map((r) => (
          <div class="result-card" style={`--card-color: ${r.color}`}>
            <div class="result-header">
              <div class="result-avatar" style={`background: ${r.color}`}>
                {r.initials}
              </div>
              <div class="result-meta">
                <strong>{r.name}</strong>
                <span>
                  {r.age} · {r.service}
                </span>
                <span class="result-duration">
                  ⏱ {r.duration} de tratamiento
                </span>
              </div>
            </div>

            <div class="result-comparison">
              <div class="result-col before-col">
                <span class="col-label before-label">ANTES</span>
                <div class="metrics">
                  <div class="metric">
                    <span class="metric-label">Peso</span>
                    <span class="metric-value">{r.before.weight}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">% Grasa</span>
                    <span class="metric-value">{r.before.fat}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">Músculo</span>
                    <span class="metric-value">{r.before.muscle}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">Visceral</span>
                    <span class="metric-value">{r.before.visceral}</span>
                  </div>
                </div>
              </div>

              <div class="result-arrow">→</div>

              <div class="result-col after-col">
                <span class="col-label after-label">DESPUÉS</span>
                <div class="metrics">
                  <div class="metric">
                    <span class="metric-label">Peso</span>
                    <span class="metric-value after">{r.after.weight}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">% Grasa</span>
                    <span class="metric-value after">{r.after.fat}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">Músculo</span>
                    <span class="metric-value after">{r.after.muscle}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">Visceral</span>
                    <span class="metric-value after">{r.after.visceral}</span>
                  </div>
                </div>
              </div>
            </div>

            <ul class="result-changes">
              {r.changes.map((c) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <circle
                      cx="7"
                      cy="7"
                      r="7"
                      fill="var(--color-accent)"
                      fill-opacity="0.2"
                    />
                    <path
                      d="M4 7l2 2 4-4"
                      stroke="var(--color-primary)"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {c}
                </li>
              ))}
            </ul>

            <blockquote class="result-quote">"{r.quote}"</blockquote>
          </div>
        ))
      }
    </div>

    <div class="results-cta">
      <p>¿Listo para ver tus propios resultados con InBody?</p>
      <a
        href="https://forms.gle/fTbGLx5JtzZ38Tot7"
        target="_blank"
        class="results-btn"
      >
        Agendar mi evaluación
      </a>
    </div>
  </div>
</section>

<style>
  .results-section {
    padding: 96px 24px;
    background: linear-gradient(
      180deg,
      var(--color-accent-lighter) 0%,
      #fff 100%
    );
  }

  .results-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .results-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .results-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .results-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
  }

  .results-subtitle {
    font-size: 1.05rem;
    color: #666;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 12px;
  }

  .results-disclaimer {
    font-size: 0.78rem;
    color: #aaa;
    margin: 0;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .result-card {
    background: #fff;
    border: 1.5px solid #ececec;
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.07);
    border-color: var(--card-color);
  }

  .result-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .result-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: #fff;
    font-size: 1rem;
    flex-shrink: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .result-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .result-meta strong {
    font-size: 1rem;
    color: #1a1a1a;
  }

  .result-meta span {
    font-size: 0.8rem;
    color: #888;
  }

  .result-duration {
    font-size: 0.78rem !important;
    color: var(--color-primary) !important;
    font-weight: 600;
  }

  .result-comparison {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fafaf8;
    border-radius: 14px;
    padding: 18px;
  }

  .result-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .col-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 50px;
    display: inline-block;
    width: fit-content;
    margin-bottom: 6px;
  }

  .before-label {
    background: #f0e6e6;
    color: #c25b5b;
  }

  .after-label {
    background: var(--color-accent-lighter);
    color: var(--color-primary);
  }

  .metrics {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .metric {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 6px;
  }

  .metric-label {
    font-size: 0.78rem;
    color: #aaa;
  }

  .metric-value {
    font-size: 0.88rem;
    font-weight: 700;
    color: #888;
  }

  .metric-value.after {
    color: var(--color-primary);
  }

  .result-arrow {
    font-size: 1.4rem;
    color: var(--color-accent);
    flex-shrink: 0;
    font-weight: 700;
  }

  .result-changes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .result-changes li {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-accent-lighter);
    padding: 5px 12px;
    border-radius: 50px;
  }

  .result-quote {
    font-size: 0.92rem;
    font-style: italic;
    color: #666;
    line-height: 1.6;
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid #f0f0f0;
  }

  .results-cta {
    text-align: center;
    margin-top: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .results-cta p {
    font-size: 1.1rem;
    color: #444;
    font-weight: 500;
    margin: 0;
  }

  .results-btn {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 15px 32px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(216, 27, 96, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .results-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(216, 27, 96, 0.4);
  }
</style>
