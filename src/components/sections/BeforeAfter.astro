---
// BeforeAfter.astro
// Sección de resultados y transformaciones con InBody data
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const results = [
  {
    initials: "MR",
    color: "#a5c4d4",
    name: "María R.",
    ageNum: 34,
    service: `${t('services.weight.title')} + ${t('services.psycho.title')}`,
    durationNum: 4,
    before: {
      weight: "82 kg",
      fat: "38%",
      muscle: "44 kg",
      visceral: 9,
    },
    after: {
      weight: "68 kg",
      fat: "24%",
      muscle: "47 kg",
      visceral: 4,
    },
    changes: [
      `-14 kg ${t('beforeAfter.weight').toLowerCase()}`,
      `-14% ${t('beforeAfter.fat').toLowerCase()}`,
      `+3 kg ${t('beforeAfter.muscle').toLowerCase()}`,
      t('beforeAfter.quote'), // This is actually a change in the original, I'll use literal strings or specific keys
    ],
    quote: "Por primera vez en años, disfruto comer sin culpa.",
  },
  {
    initials: "JP",
    color: "#FFD1DC",
    name: "Jorge P.",
    ageNum: 41,
    service: t('services.sports.title'),
    durationNum: 3,
    before: {
      weight: "78 kg",
      fat: "22%",
      muscle: "58 kg",
      visceral: 7,
    },
    after: {
      weight: "81 kg",
      fat: "14%",
      muscle: "66 kg",
      visceral: 3,
    },
    changes: [],
    quote: "El InBody me mostró que no se trata del peso, sino de la composición.",
  },
  {
    initials: "LC",
    color: "#d4a5c9",
    name: "Laura C.",
    ageNum: 28,
    service: `${t('services.hormone.title')} (SOP)`,
    durationNum: 5,
    before: {
      weight: "74 kg",
      fat: "35%",
      muscle: "45 kg",
      visceral: 8,
    },
    after: {
      weight: "63 kg",
      fat: "22%",
      muscle: "47 kg",
      visceral: 3,
    },
    changes: [],
    quote: "Mi SOP mejoró muchísimo. Nunca pensé que la nutrición fuera tan clave.",
  },
];

// Refined changes and quotes based on language
const localizedData = [
  {
    ...results[0],
    age: `${results[0].ageNum} ${t('beforeAfter.yearsOld')}`,
    duration: `${results[0].durationNum} ${t('beforeAfter.months')}`,
    changes: lang === 'es' ? [
      "-14 kg de peso",
      "-14% grasa corporal",
      "+3 kg músculo",
      "Grasa visceral normalizada",
    ] : [
      "-14 kg weight",
      "-14% body fat",
      "+3 kg muscle",
      "Normalized visceral fat",
    ],
    quote: lang === 'es' ? "Por primera vez en años, disfruto comer sin culpa." : "For the first time in years, I enjoy eating without guilt.",
  },
  {
    ...results[1],
    age: `${results[1].ageNum} ${t('beforeAfter.yearsOld')}`,
    duration: `${results[1].durationNum} ${t('beforeAfter.months')}`,
    changes: lang === 'es' ? [
      "+3 kg (recomposición)",
      "-8% grasa corporal",
      "+8 kg músculo",
      "Rendimiento deportivo ↑",
    ] : [
      "+3 kg (recomposition)",
      "-8% body fat",
      "+8 kg muscle",
      "Sports performance ↑",
    ],
    quote: lang === 'es' ?
      "El InBody me mostró que no se trata del peso, sino de la composición." :
      "The InBody showed me that it's not about weight, but about composition.",
  },
  {
    ...results[2],
    age: `${results[2].ageNum} ${t('beforeAfter.yearsOld')}`,
    duration: `${results[2].durationNum} ${t('beforeAfter.months')}`,
    changes: lang === 'es' ? [
      "-11 kg de peso",
      "Ciclos menstruales regulares",
      "-13% grasa corporal",
      "Resistencia a insulina revertida",
    ] : [
      "-11 kg weight",
      "Regular menstrual cycles",
      "-13% body fat",
      "Insulin resistance reversed",
    ],
    quote: lang === 'es' ?
      "Mi SOP mejoró muchísimo. Nunca pensé que la nutrición fuera tan clave." :
      "My PCOS improved a lot. I never thought nutrition was so key.",
  },
];
---

<section id="results" class="results-section">
  <div class="results-container">
    <div class="results-header">
      <span class="results-eyebrow">{t('beforeAfter.eyebrow')}</span>
      <h2 class="results-title">
        {t('beforeAfter.title').split('InBody').map((part, i, arr) => (
          <>
            {part}
            {i < arr.length - 1 && (
              <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">InBody</span>
            )}
          </>
        ))}
      </h2>
      <p class="results-subtitle">
        {t('beforeAfter.subtitle')}
      </p>
      <p class="results-disclaimer">
        {t('beforeAfter.disclaimer')}
      </p>
    </div>

    <div class="results-grid">
      {
        localizedData.map((r) => (
          <div class="result-card" style={`--card-color: ${r.color}`}>
            <div class="result-header">
              <div class="result-avatar" style={`background: ${r.color}`}>
                {r.initials}
              </div>
              <div class="result-meta">
                <strong>{r.name}</strong>
                <span>
                  {r.age} · {r.service}
                </span>
                <span class="result-duration">
                  ⏱ {r.duration}
                </span>
              </div>
            </div>

            <div class="result-comparison">
              <div class="result-col before-col">
                <span class="col-label before-label">{t('beforeAfter.before')}</span>
                <div class="metrics">
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.weight')}</span>
                    <span class="metric-value">{r.before.weight}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.fat')}</span>
                    <span class="metric-value">{r.before.fat}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.muscle')}</span>
                    <span class="metric-value">{r.before.muscle}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.visceral')}</span>
                    <span class="metric-value">{t('beforeAfter.level')} {r.before.visceral}</span>
                  </div>
                </div>
              </div>

              <div class="result-arrow">→</div>

              <div class="result-col after-col">
                <span class="col-label after-label">{t('beforeAfter.after')}</span>
                <div class="metrics">
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.weight')}</span>
                    <span class="metric-value after">{r.after.weight}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.fat')}</span>
                    <span class="metric-value after">{r.after.fat}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.muscle')}</span>
                    <span class="metric-value after">{r.after.muscle}</span>
                  </div>
                  <div class="metric">
                    <span class="metric-label">{t('beforeAfter.visceral')}</span>
                    <span class="metric-value after">{t('beforeAfter.level')} {r.after.visceral}</span>
                  </div>
                </div>
              </div>
            </div>

            <ul class="result-changes">
              {r.changes.map((c) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <circle
                      cx="7"
                      cy="7"
                      r="7"
                      fill="var(--color-accent)"
                      fill-opacity="0.2"
                    />
                    <path
                      d="M4 7l2 2 4-4"
                      stroke="var(--color-primary)"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {c}
                </li>
              ))}
            </ul>

            <blockquote class="result-quote">"{r.quote}"</blockquote>
          </div>
        ))
      }
    </div>

    <div class="results-cta">
      <p>{t('beforeAfter.ctaText')}</p>
      <a
        href="https://forms.gle/fTbGLx5JtzZ38Tot7"
        target="_blank"
        class="results-btn"
      >
        {t('beforeAfter.ctaButton')}
      </a>
    </div>
  </div>
</section>

<style>
  .results-section {
    padding: 80px 24px;
    background: var(--color-accent-lighter);
  }

  .results-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .results-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .results-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .results-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
  }

  .results-subtitle {
    font-size: 1.05rem;
    color: #666;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 12px;
  }

  .results-disclaimer {
    font-size: 0.78rem;
    color: #aaa;
    margin: 0;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .result-card {
    background: #fff;
    border: 1.5px solid #ececec;
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.07);
    border-color: var(--card-color);
  }

  .result-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .result-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: #fff;
    font-size: 1rem;
    flex-shrink: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .result-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .result-meta strong {
    font-size: 1rem;
    color: #1a1a1a;
  }

  .result-meta span {
    font-size: 0.8rem;
    color: #888;
  }

  .result-duration {
    font-size: 0.78rem !important;
    color: var(--color-primary) !important;
    font-weight: 600;
  }

  .result-comparison {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fafaf8;
    border-radius: 14px;
    padding: 18px;
  }

  .result-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .col-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 50px;
    display: inline-block;
    width: fit-content;
    margin-bottom: 6px;
  }

  .before-label {
    background: #f0e6e6;
    color: #c25b5b;
  }

  .after-label {
    background: var(--color-accent-lighter);
    color: var(--color-primary);
  }

  .metrics {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .metric {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 6px;
  }

  .metric-label {
    font-size: 0.78rem;
    color: #aaa;
  }

  .metric-value {
    font-size: 0.88rem;
    font-weight: 700;
    color: #888;
  }

  .metric-value.after {
    color: var(--color-primary);
  }

  .result-arrow {
    font-size: 1.4rem;
    color: var(--color-accent);
    flex-shrink: 0;
    font-weight: 700;
  }

  .result-changes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .result-changes li {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-accent-lighter);
    padding: 5px 12px;
    border-radius: 50px;
  }

  .result-quote {
    font-size: 0.92rem;
    font-style: italic;
    color: #666;
    line-height: 1.6;
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid #f0f0f0;
  }

  .results-cta {
    text-align: center;
    margin-top: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .results-cta p {
    font-size: 1.1rem;
    color: #444;
    font-weight: 500;
    margin: 0;
  }

  .results-btn {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 15px 32px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(216, 27, 96, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .results-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(216, 27, 96, 0.4);
  }
</style>
