---
import { Image } from "astro:assets";
import inbodyImg from "../../assets/inbody-real.jpg";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="equipment" class="py-16 lg:py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:flex lg:items-center gap-16">
      <div class="lg:w-1/2 mb-16 lg:mb-0">
        <span class="text-primary font-semibold tracking-wider uppercase text-sm"
          >{t('equipment.label')}</span
        >
        <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 mt-4 mb-8">
          {t('equipment.title').split('InBody 270').map((part, i, arr) => (
            <>
              {part}
              {i < arr.length - 1 && (
                <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">InBody 270</span>
              )}
            </>
          ))}
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          {t('equipment.description')}
        </p>

        <div class="grid sm:grid-cols-2 gap-6">
          <div class="p-6 rounded-2xl bg-pink-50 border border-pink-100">
            <h4 class="font-bold text-slate-900 mb-2 flex items-center gap-2">
              <span class="text-xl">🧬</span> {t('equipment.feature1.title')}
            </h4>
            <p class="text-sm text-slate-600">
              {t('equipment.feature1.desc')}
            </p>
          </div>
          <div class="p-6 rounded-2xl bg-pink-50 border border-pink-100">
            <h4 class="font-bold text-slate-900 mb-2 flex items-center gap-2">
              <span class="text-xl">📊</span> {t('equipment.feature2.title')}
            </h4>
            <p class="text-sm text-slate-600">
              {t('equipment.feature2.desc')}
            </p>
          </div>
          <div class="p-6 rounded-2xl bg-pink-50 border border-pink-100">
            <h4 class="font-bold text-slate-900 mb-2 flex items-center gap-2">
              <span class="text-xl">🔥</span> {t('equipment.feature3.title')}
            </h4>
            <p class="text-sm text-slate-600">
              {t('equipment.feature3.desc')}
            </p>
          </div>
          <div class="p-6 rounded-2xl bg-pink-50 border border-pink-100">
            <h4 class="font-bold text-slate-900 mb-2 flex items-center gap-2">
              <span class="text-xl">📈</span> {t('equipment.feature4.title')}
            </h4>
            <p class="text-sm text-slate-600">
              {t('equipment.feature4.desc')}
            </p>
          </div>
        </div>
      </div>

      <div class="lg:w-1/2 relative">
        <div
          class="relative z-10 rounded-3xl overflow-hidden shadow-2xl bg-slate-50 aspect-[4/5]"
        >
          <Image
            src={inbodyImg}
            alt="Consultorio Nutrilev - InBody 270"
            class="w-full h-full object-cover object-top"
          />
        </div>
        <!-- Decorative background circles -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-pink-100/50 rounded-full mix-blend-multiply filter blur-3xl -z-0"
        >
        </div>

        <div
          class="absolute -top-10 -left-10 bg-white p-4 rounded-xl shadow-lg border border-pink-50 z-20 hidden sm:block animate-bounce"
        >
          <p class="text-primary font-bold text-sm">
            {t('equipment.badge')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
