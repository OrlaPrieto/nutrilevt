---
// FAQ.astro
// Sección de preguntas frecuentes con acordeón animado
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { q: t('faq.q1'), a: t('faq.a1') },
  { q: t('faq.q2'), a: t('faq.a2') },
  { q: t('faq.q3'), a: t('faq.a3') },
  { q: t('faq.q4'), a: t('faq.a4') },
  { q: t('faq.q5'), a: t('faq.a5') },
  { q: t('faq.q6'), a: t('faq.a6') },
  { q: t('faq.q7'), a: t('faq.a7') },
  { q: t('faq.q8'), a: t('faq.a8') },
  { q: t('faq.q9'), a: t('faq.a9') },
  { q: t('faq.q10'), a: t('faq.a10') },
];
---

<section id="faq" class="faq-section">
  <div class="faq-container">
    <div class="faq-header">
      <span class="faq-eyebrow">{t('faq.label')}</span>
      <h2 class="faq-title">
        {t('faq.title').split(lang === 'es' ? 'Frecuentes' : 'Questions').map((part, i, arr) => (
          <>
            {part}
            {i < arr.length - 1 && (
              <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">{lang === 'es' ? 'Frecuentes' : 'Questions'}</span>
            )}
          </>
        ))}
      </h2>
      <p class="faq-subtitle">
        {t('faq.subtitle')}
      </p>
    </div>

    <div class="faq-grid">
      {
        faqs.map((faq, index) => (
          <div class="faq-item" data-index={index}>
            <button class="faq-question" aria-expanded="false">
              <span class="faq-q-text">{faq.q}</span>
              <span class="faq-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path
                    d="M5 7.5L10 12.5L15 7.5"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </button>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="faq-cta">
      <p>{t('faq.other')}</p>
      <a
        href="https://wa.me/526143958598?text=Hola%2C%20tengo%20una%20pregunta%20sobre%20los%20servicios%20de%20Nutrilev"
        target="_blank"
        class="faq-wa-btn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          width="18"
          height="18"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        {t('faq.whatsapp')}
      </a>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 80px 24px;
    background: #f8fafc;
  }

  .faq-container {
    max-width: 780px;
    margin: 0 auto;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .faq-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .faq-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 16px;
    line-height: 1.15;
  }

  .faq-subtitle {
    font-size: 1.05rem;
    color: #4a5568;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto;
  }

  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .faq-item {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #ebebeb;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 8px;
  }

  .faq-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 16px rgba(216, 27, 96, 0.1);
  }

  .faq-item.active {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(216, 27, 96, 0.15);
  }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
    transition: background 0.2s ease;
  }

  .faq-question:hover {
    background: var(--color-accent-lighter);
  }

  .faq-q-text {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    flex: 1;
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--color-primary);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex;
    align-items: center;
  }

  .faq-item.active .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-answer p {
    padding: 0 24px 22px;
    font-size: 0.97rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .faq-item.active .faq-answer {
    max-height: 400px;
  }

  .faq-cta {
    margin-top: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .faq-cta p {
    font-size: 1rem;
    color: #666;
    margin: 0;
  }

  .faq-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: #fff;
    padding: 12px 22px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 14px rgba(216, 27, 96, 0.3);
  }

  .faq-wa-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 107, 155, 0.4);
  }
</style>

<script>
  function initFAQ() {
    const faqContainer = document.getElementById("faq");
    if (!faqContainer || faqContainer.hasAttribute("data-initialized")) return;
    faqContainer.setAttribute("data-initialized", "true");

    const items = document.querySelectorAll(".faq-item");
    items.forEach((item) => {
      const btn = item.querySelector(".faq-question");
      btn?.addEventListener("click", () => {
        const isActive = item.classList.contains("active");
        // Cierra todos
        items.forEach((i) => {
          i.classList.remove("active");
          i.querySelector(".faq-question")?.setAttribute(
            "aria-expanded",
            "false"
          );
        });
        // Abre el clickeado si no estaba abierto
        if (!isActive) {
          item.classList.add("active");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initFAQ);
</script>
