---
import { Image } from "astro:assets";
import logoImg from "../../assets/logo_nutrilev_final_2.png";
import WhatsAppIcon from "../ui/icons/WhatsAppIcon.astro";
import InstagramIcon from "../ui/icons/InstagramIcon.astro";
import FacebookIcon from "../ui/icons/FacebookIcon.astro";
import LanguagePicker from "../ui/LanguagePicker.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langPath = lang === "es" ? "" : `/${lang}`;
---

<header class="fixed top-0 left-0 w-full z-50" transition:persist>
  <!-- Top Bar -->
  <div class="bg-primary text-white py-2 px-4 sm:px-6 lg:px-8">
    <div
      class="max-w-7xl mx-auto flex justify-between items-center text-xs sm:text-sm font-medium"
    >
      <div class="hidden sm:block uppercase tracking-wider">
        {
          lang === "es"
            ? "Nutrición Clínica Especializada"
            : "Specialized Clinical Nutrition"
        }
      </div>
      <div class="flex items-center gap-4 ml-auto sm:ml-0">
        <LanguagePicker />
        <div class="h-4 w-[1px] bg-white/20 hidden sm:block"></div>
        <a
          href="https://wa.me/526143958598"
          target="_blank"
          aria-label="WhatsApp"
          class="flex items-center gap-1.5 hover:text-white/80 transition-colors"
        >
          <WhatsAppIcon class="w-4 h-4" />
          <span class="hidden xs:inline">WhatsApp</span>
        </a>
        <a
          href="https://www.instagram.com/nutrilev_especializada"
          target="_blank"
          aria-label="Instagram"
          class="flex items-center gap-1.5 hover:text-white/80 transition-colors"
        >
          <InstagramIcon class="w-4 h-4" />
          <span class="hidden xs:inline">Instagram</span>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=100064033451986"
          target="_blank"
          aria-label="Facebook"
          class="flex items-center gap-1.5 hover:text-white/80 transition-colors"
        >
          <FacebookIcon class="w-4 h-4" />
          <span class="hidden xs:inline">Facebook</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <nav
    id="main-nav"
    class="bg-white/60 backdrop-blur-xl border-b border-white/20 relative transition-all duration-300"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20 md:h-32">
        <div class="flex-shrink-0">
          <a href={`${langPath}/`} class="block logo-container">
            <Image
              src={logoImg}
              alt="Nutrilev Logo"
              class="logo-img object-contain"
              loading="eager"
              fetchpriority="high"
              width={292}
              height={112}
              quality={50}
            />
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
          <button
            id="mobile-menu-button"
            class="text-slate-600 hover:text-primary p-2 focus:outline-none transition-colors"
            aria-label="Menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              id="hamburger-icon"
              class="w-8 h-8"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              id="close-icon"
              class="w-8 h-8 hidden"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-1">
          <a
            href={`${langPath}/`}
            class="text-slate-600 hover:text-primary px-4 py-2 text-sm font-semibold transition-colors"
            >{t("nav.inicio")}</a
          >

          <a
            href={`${langPath}/#services`}
            class="text-slate-600 hover:text-primary px-4 py-2 text-sm font-semibold transition-colors"
            >{t("nav.servicios")}</a
          >

          <a
            href={`${langPath}/#consultation-modes`}
            class="text-slate-600 hover:text-primary px-4 py-2 text-sm font-semibold transition-colors"
            >{t("nav.modalidades")}</a
          >

          <a
            href={`${langPath}/#clinical-history`}
            class="text-slate-600 hover:text-primary px-4 py-2 text-sm font-semibold transition-colors"
            >{t("nav.historial")}</a
          >

          <a
            href={`${langPath}/#faq`}
            class="text-slate-600 hover:text-primary px-4 py-2 text-sm font-semibold transition-colors"
            >{t("nav.faq")}</a
          >
          <div class="ml-4">
            <a
              href={`${langPath}/#booking`}
              class="relative inline-block bg-primary text-white px-8 py-3 rounded-full text-sm font-bold transition-all shadow-glow hover:shadow-glow-lg hover:scale-110 active:scale-95 animate-gentle-pulse animate-shimmer"
            >
              <span class="relative z-10">{t("nav.agendar")}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-[120px] md:hidden bg-[#FFFFFF] z-50 transform translate-x-full transition-transform duration-300 ease-in-out border-t border-pink-50"
  >
    <div
      class="flex flex-col items-center justify-start h-full pt-12 space-y-8 px-6 text-center"
    >
      <a
        href={`${langPath}/`}
        class="mobile-link text-2xl font-bold text-slate-800 hover:text-primary transition-colors"
        >{t("nav.inicio")}</a
      >

      <a
        href={`${langPath}/#services`}
        class="mobile-link text-2xl font-bold text-slate-800 hover:text-primary transition-colors"
        >{t("nav.servicios")}</a
      >

      <a
        href={`${langPath}/#consultation-modes`}
        class="mobile-link text-2xl font-bold text-slate-800 hover:text-primary transition-colors"
        >{t("nav.modalidades")}</a
      >

      <a
        href={`${langPath}/#clinical-history`}
        class="mobile-link text-2xl font-bold text-slate-800 hover:text-primary transition-colors"
        >{t("nav.historial")}</a
      >

      <a
        href={`${langPath}/#faq`}
        class="mobile-link text-2xl font-bold text-slate-800 hover:text-primary transition-colors"
        >{t("nav.faq")}</a
      >
      <div class="pt-6 w-full">
        <a
          href={`${langPath}/#booking`}
          class="mobile-link block w-full bg-primary text-white py-5 rounded-2xl text-xl font-bold shadow-xl shadow-pink-100 active:scale-95 transition-transform"
        >
          {t("nav.agendar")}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initNavbar() {
    const header = document.querySelector("header");
    if (!header || header.hasAttribute("data-initialized")) return;
    header.setAttribute("data-initialized", "true");

    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function toggleMenu() {
      const isOpened = !mobileMenu?.classList.contains("translate-x-full");

      if (isOpened) {
        mobileMenu?.classList.add("translate-x-full");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        document.body.style.overflow = "";
        mobileMenuButton?.setAttribute("aria-expanded", "false");
      } else {
        mobileMenu?.classList.remove("translate-x-full");
        hamburgerIcon?.classList.add("hidden");
        closeIcon?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        mobileMenuButton?.setAttribute("aria-expanded", "true");
      }
    }

    mobileMenuButton?.addEventListener("click", toggleMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu?.classList.add("translate-x-full");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        document.body.style.overflow = "";
      });
    });

    // Dynamic Navbar on Scroll - Synchronized with Animation Frames
    const mainNav = document.getElementById("main-nav");
    let ticking = false;

    const handleScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          if (scrollY > 20) {
            mainNav?.classList.add(
              "bg-white/90",
              "backdrop-blur-xl",
              "shadow-md",
              "border-pink-100/50",
            );
            mainNav?.classList.remove(
              "bg-white/40",
              "backdrop-blur-md",
              "border-transparent",
            );
          } else {
            mainNav?.classList.remove(
              "bg-white/90",
              "backdrop-blur-xl",
              "shadow-md",
              "border-pink-100/50",
            );
            mainNav?.classList.add(
              "bg-white/40",
              "backdrop-blur-md",
              "border-transparent",
            );
          }
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    // Initial check
    handleScroll();
  }

  // Defer non-critical initialization to free up the main thread during navigation
  document.addEventListener("astro:page-load", () => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => initNavbar());
    } else {
      setTimeout(initNavbar, 1);
    }
  });
</script>

<style>
  @keyframes gentle-pulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 10px rgba(255, 107, 155, 0.4);
    }
    50% {
      transform: scale(1.08);
      box-shadow: 0 0 25px rgba(216, 27, 96, 0.6);
    }
  }

  @keyframes shimmer-auto {
    0% {
      transform: translateX(-200%) skewX(-25deg);
    }
    20%,
    100% {
      transform: translateX(200%) skewX(-25deg);
    }
  }

  .animate-gentle-pulse {
    animation: gentle-pulse 2s infinite ease-in-out;
  }

  /* Automatic glint/shimmer every 5 seconds */
  .animate-shimmer-auto {
    animation: shimmer-auto 5s infinite cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Critical Landing Performance: Explicit LCP Dimensions */
  .logo-container {
    display: block;
    height: 64px; /* Mobile header height equivalent */
    aspect-ratio: 292 / 112;
  }

  .logo-img {
    height: 100%;
    width: auto;
  }

  @media (min-width: 768px) {
    .logo-container {
      height: 96px; /* Desktop height equivalent */
    }
  }
</style>
