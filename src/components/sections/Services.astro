---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    title: t('services.clinical.title'),
    description: t('services.clinical.desc'),
    details: t('services.clinical.details').split('|'),
    icon: "🏥",
    color: "bg-pink-50",
  },
  {
    title: t('services.psycho.title'),
    description: t('services.psycho.desc'),
    details: t('services.psycho.details').split('|'),
    icon: "🧠",
    color: "bg-pink-100",
  },
  {
    title: t('services.hormone.title'),
    description: t('services.hormone.desc'),
    details: t('services.hormone.details').split('|'),
    icon: "🌸",
    color: "bg-accent-light",
  },
  {
    title: t('services.weight.title'),
    description: t('services.weight.desc'),
    details: t('services.weight.details').split('|'),
    icon: "⚖️",
    color: "bg-pink-50",
  },
  {
    title: t('services.sports.title'),
    description: t('services.sports.desc'),
    details: t('services.sports.details').split('|'),
    icon: "🏃‍♀️",
    color: "bg-pink-100",
  },
];
---

<section id="services" class="py-16 lg:py-20 bg-rose-50/30 fade-in-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-accent font-semibold tracking-wider uppercase text-sm"
        >{t('services.label')}</span
      >
      <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 mt-4">
        {t('services.title').split(lang === 'es' ? 'ti' : 'you').map((part, i, arr) => (
          <>
            {part}
            {i < arr.length - 1 && (
              <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">{lang === 'es' ? 'ti' : 'you'}</span>
            )}
          </>
        ))}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-8">
      {
        services.map((service, index) => (
          <div
            class={`group p-10 rounded-3xl bg-white border border-pink-50 hover:border-accent transition-all duration-500 hover:-translate-y-3 shadow-sm hover:shadow-2xl hover:shadow-pink-100/50 flex flex-col h-full
          col-span-1 
          md:col-span-2 
          lg:col-span-2
          ${index === 4 ? "md:col-start-2 lg:col-start-4" : ""} 
          ${index === 3 ? "lg:col-start-2" : ""}
        `}
          >
            <div
              class={`w-16 h-16 ${service.color} rounded-2xl flex items-center justify-center text-3xl mb-8 mx-auto group-hover:scale-110 transition-transform`}
            >
              {service.icon}
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              {service.title}
            </h3>
            <p class="text-slate-600 leading-relaxed mb-6 font-medium">
              {service.description}
            </p>
            {service.details && (
              <ul class="text-left text-slate-600 space-y-2 text-sm">
                {service.details.map((detail) => (
                  <li class="flex items-start gap-2">
                    <span class="text-accent mt-1">•</span>
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
