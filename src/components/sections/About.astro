---
import { Image } from "astro:assets";
import nutritionistImg from "../../assets/nutritionist-strawberry.jpg";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="py-16 lg:py-20 bg-white fade-in-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:flex lg:items-center gap-16">
      <div class="lg:w-1/2 order-2 lg:order-1">
        <div class="relative">
          <Image
            src={nutritionistImg}
            alt="Nutrióloga Nutrilev"
            class="rounded-3xl shadow-xl w-full h-auto max-h-[600px] object-contain bg-slate-50"
          />
          <div
            class="absolute -bottom-8 -right-8 bg-white p-6 rounded-2xl shadow-xl border border-pink-50 max-w-xs transition-transform hover:-translate-y-2"
          >
            <p class="text-primary font-bold text-3xl mb-1">{t('about.badge.years')}</p>
            <p class="text-slate-600 text-sm font-medium">
              {t('about.badge.desc')}
            </p>
          </div>
        </div>
      </div>
      <div class="lg:w-1/2 order-1 lg:order-2 mb-16 lg:mb-0">
        <span class="text-accent font-semibold tracking-wider uppercase text-sm"
          >{t('about.label')}</span
        >
        <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 mt-4 mb-8">
          {t('about.title').split('Velvet De la Cruz').map((part, i, arr) => (
            <>
              {part}
              {i < arr.length - 1 && (
                <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">Velvet De la Cruz</span>
              )}
            </>
          ))}
        </h2>
        <div class="space-y-6 text-lg text-slate-600 leading-relaxed">
          <p>
            {t('about.p1')}
          </p>
          <p>
            {t('about.p2')}
          </p>
          <ul class="space-y-4 pt-4">
            <li class="flex items-start gap-3">
              <span
                class="w-6 h-6 rounded-full bg-pink-100 flex items-center justify-center text-primary text-sm mt-1 flex-shrink-0"
                >✓</span
              >
              <span
                ><strong>{t('about.expertise.psiconutricion.title')}</strong> {t('about.expertise.psiconutricion.desc')}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="w-6 h-6 rounded-full bg-pink-100 flex items-center justify-center text-primary text-sm mt-1 flex-shrink-0"
                >✓</span
              >
              <span
                ><strong>{t('about.expertise.salud.title')}</strong> {t('about.expertise.salud.desc')}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="w-6 h-6 rounded-full bg-pink-100 flex items-center justify-center text-primary text-sm mt-1 flex-shrink-0"
                >✓</span
              >
              <span
                ><strong>{t('about.expertise.etapas.title')}</strong> {t('about.expertise.etapas.desc')}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="w-6 h-6 rounded-full bg-pink-100 flex items-center justify-center text-primary text-sm mt-1 flex-shrink-0"
                >✓</span
              >
              <span
                ><strong>{t('about.expertise.deporte.title')}</strong> {t('about.expertise.deporte.desc')}</span
              >
            </li>
          </ul>
          <p class="pt-4 font-medium italic text-slate-800">
            {t('about.p3')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
