---
import { Image } from "astro:assets";
import heroImg from "../../assets/hands-strawberries.jpg";
---

<section
  id="inicio"
  class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-mesh fade-in-section pt-32 lg:pt-48"
  aria-label="Presentación principal"
>
  <!-- Background Blobs -->
  <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px] animate-pulse"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-accent/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="lg:flex lg:items-center lg:gap-16">
      <div class="lg:w-1/2 mb-12 lg:mb-0">
        <h1
          class="text-6xl lg:text-8xl font-bold text-slate-900 leading-[1.1] mb-8 font-serif"
        >
          Nutrición <span class="italic text-primary">consciente</span> para una
          vida plena.
        </h1>
        <p class="text-xl lg:text-2xl text-slate-600 mb-10 max-w-xl leading-relaxed">
          Transforma tu relación con la comida mediante un enfoque <span class="text-primary font-medium">especializado</span> y personalizado que se adapta a tu estilo de vida.
        </p>
        <div class="flex flex-col sm:flex-row gap-5">
          <a
            href="#services"
            class="bg-primary text-white px-10 py-5 rounded-full font-bold text-center hover:scale-105 active:scale-95 transition-all shadow-glow hover:shadow-glow-lg animate-shimmer"
          >
            Descubre nuestros servicios
          </a>
          <a
            href="#about"
            class="border-2 border-primary/20 text-primary px-10 py-5 rounded-full font-bold text-center hover:bg-primary/5 hover:border-primary/40 transition-all flex items-center justify-center gap-2"
          >
            Conoce más <span class="text-lg">→</span>
          </a>
        </div>
        <div class="mt-14 flex items-center gap-6">
          <div class="flex -space-x-3">
            {
              [1, 2, 3, 4].map(() => (
                <div class="w-10 h-10 rounded-full border-2 border-white bg-white shadow-sm flex items-center justify-center overflow-hidden">
                   <div class="w-full h-full bg-gradient-to-br from-pink-100 to-pink-50 flex items-center justify-center">
                    <span class="text-xs text-primary">❤</span>
                   </div>
                </div>
              ))
            }
          </div>
          <div class="flex flex-col">
            <span class="text-slate-900 font-bold text-lg">+500 vidas</span>
            <span class="text-slate-500 text-sm">transformadas con éxito</span>
          </div>
        </div>
      </div>
      <div class="lg:w-1/2 relative">
        <div class="relative">
          <!-- Decorative leaf or shape -->
          <div class="absolute -top-10 -right-10 w-24 h-24 bg-accent/20 rounded-full blur-2xl animate-bounce" style="animation-duration: 4s;"></div>
          
          <div
            class="relative rounded-[2.5rem] overflow-hidden shadow-2xl transform hover:rotate-1 transition-transform duration-700 border-8 border-white"
          >
            <Image
              src={heroImg}
              alt="Nutrición Saludable - Nutrilev"
              class="w-full h-[650px] object-cover hover:scale-105 transition-transform duration-1000"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
          </div>

          <!-- Float Badge -->
          <div class="absolute -bottom-6 -left-6 bg-white p-5 rounded-2xl shadow-2xl animate-float max-w-[180px] hidden sm:block">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600">✓</div>
              <p class="text-xs font-bold text-slate-800">Planes 100% Personalizados</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>

