---
// IntakeForm.astro
---

<!-- Flatpickr CSS -->
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
/>
<style is:global>
    /* Flatpickr Custom Theme */
    .flatpickr-calendar {
        background: #fff;
        box-shadow: 0 10px 25px -5px rgba(216, 27, 96, 0.1),
            0 8px 10px -6px rgba(216, 27, 96, 0.1) !important;
        border: 1px solid #fce7f3 !important;
        border-radius: 1.5rem !important;
        padding: 0.5rem;
    }
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange,
    .flatpickr-day.selected.prevMonthDay,
    .flatpickr-day.selected.nextMonthDay,
    .flatpickr-day.startRange.prevMonthDay,
    .flatpickr-day.startRange.nextMonthDay,
    .flatpickr-day.endRange.prevMonthDay,
    .flatpickr-day.endRange.nextMonthDay {
        background: #d81b60 !important;
        border-color: #d81b60 !important;
        color: #fff !important;
        border-radius: 0.75rem !important;
    }
    .flatpickr-day:hover {
        background: #fce7f3 !important;
        border-color: #fce7f3 !important;
    }
    .flatpickr-months .flatpickr-month {
        color: #0f172a !important;
        fill: #0f172a !important;
    }
    .flatpickr-current-month .flatpickr-monthDropdown-months {
        font-weight: 700 !important;
    }
    .flatpickr-weekday {
        color: #64748b !important;
        font-weight: 600 !important;
    }
</style>

<div
    id="intake-form-container"
    class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-pink-50 relative"
>
    <!-- Progress Bar -->
    <div class="h-2 bg-pink-50 w-full overflow-hidden">
        <div
            id="form-progress"
            class="h-full bg-primary transition-all duration-500 w-[14%]"
        >
        </div>
    </div>

    <form id="clinical-form" class="p-8 sm:p-12" novalidate>
        <!-- Step 1: Personal Data Part 1 -->
        <div class="form-step active" data-step="1">
            <div class="text-center mb-10">
                <span
                    class="text-primary font-bold text-sm uppercase tracking-wider"
                    >Paso 1 de 7</span
                >
                <h3 class="text-3xl font-bold text-slate-900 mt-2">
                    Datos Personales
                </h3>
                <p class="text-slate-500 mt-2">
                    Comencemos con tu información básica.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Correo electrónico *</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                        placeholder="tu@email.com"
                    />
                </div>
                <div class="relative group">
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Fecha de hoy *</label
                    >
                    <div class="relative">
                        <input
                            type="text"
                            id="fecha_hoy"
                            name="fecha_hoy"
                            required
                            readonly
                            class="w-full px-4 py-3 pl-11 rounded-xl border border-slate-200 bg-slate-50 cursor-pointer outline-none transition-all modern-date-input"
                            placeholder="Seleccionar fecha"
                        />
                        <div
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    x="3"
                                    y="4"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="16"
                                    y1="2"
                                    x2="16"
                                    y2="6"></line><line
                                    x1="8"
                                    y1="2"
                                    x2="8"
                                    y2="6"></line><line
                                    x1="3"
                                    y1="10"
                                    x2="21"
                                    y2="10"></line>
                            </svg>
                        </div>
                    </div>
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Nombre completo: *</label
                    >
                    <input
                        type="text"
                        name="nombre"
                        required
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                        placeholder="Nombre Apellido"
                    />
                </div>
                <div class="relative group">
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Fecha de nacimiento: *</label
                    >
                    <div class="relative">
                        <input
                            type="text"
                            id="fecha_nacimiento"
                            name="fecha_nacimiento"
                            required
                            class="w-full px-4 py-3 pl-11 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all modern-date-input"
                            placeholder="Selecciona tu fecha"
                        />
                        <div
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors pointer-events-none"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    x="3"
                                    y="4"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="16"
                                    y1="2"
                                    x2="16"
                                    y2="6"></line><line
                                    x1="8"
                                    y1="2"
                                    x2="8"
                                    y2="6"></line><line
                                    x1="3"
                                    y1="10"
                                    x2="21"
                                    y2="10"></line>
                            </svg>
                        </div>
                    </div>
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Edad: *</label
                    >
                    <input
                        type="number"
                        id="edad"
                        name="edad"
                        required
                        readonly
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 cursor-not-allowed outline-none transition-all"
                        placeholder="Se calcula automáticamente"
                    />
                </div>
                <div class="md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Dirección</label
                    >
                    <input
                        type="text"
                        name="direccion"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                        placeholder="Calle, Número, Colonia"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Teléfono: *</label
                    >
                    <input
                        type="tel"
                        id="telefono"
                        name="telefono"
                        required
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                        placeholder="(555)-5555555"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Estatura: *</label
                    >
                    <input
                        type="text"
                        id="estatura"
                        name="estatura"
                        required
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                        placeholder="1.90"
                    />
                </div>
            </div>
        </div>

        <!-- Step 2: Personal Data Part 2 -->
        <div class="form-step" data-step="2">
            <div class="text-center mb-10">
                <span
                    class="text-primary font-bold text-sm uppercase tracking-wider"
                    >Paso 2 de 7</span
                >
                <h3 class="text-3xl font-bold text-slate-900 mt-2">
                    Perfil y Motivo
                </h3>
                <p class="text-slate-500 mt-2">
                    Cuéntanos más sobre ti y por qué vienes.
                </p>
            </div>

            <div class="space-y-8">
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Género *</label
                    >
                    <div class="grid grid-cols-2 gap-3">
                        {
                            [
                                "Femenino",
                                "Masculino",
                                "Prefiero no decirlo",
                                "No binario",
                            ].map((opt) => (
                                <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-primary/30 cursor-pointer transition-all">
                                    <input
                                        type="radio"
                                        name="genero"
                                        value={opt}
                                        required
                                        class="w-5 h-5 text-primary focus:ring-primary"
                                    />
                                    <span class="text-sm text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Estado Civil *</label
                    >
                    <div class="grid grid-cols-3 gap-3">
                        {
                            ["Soltero", "Casado", "Prefiero no decirlo"].map(
                                (opt) => (
                                    <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-primary/30 cursor-pointer transition-all">
                                        <input
                                            type="radio"
                                            name="estado_civil"
                                            value={opt}
                                            required
                                            class="w-5 h-5 text-primary focus:ring-primary"
                                        />
                                        <span class="text-sm text-slate-600">
                                            {opt}
                                        </span>
                                    </label>
                                )
                            )
                        }
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Motivos de consulta *</label
                    >
                    <textarea
                        name="motivos_consulta"
                        required
                        rows="3"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
                        placeholder="Describe brevemente tus objetivos..."
                    ></textarea>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >¿De parte de quien tiene recomendaciones sobre mis
                        servicios? *</label
                    >
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        {
                            [
                                "Amig@",
                                "Familiar",
                                "Prefiero no decirlo",
                                "Facebook",
                                "Instagram",
                                "Google",
                                "Pagina web NUTRILEV",
                            ].map((opt) => (
                                <label class="flex items-center gap-2 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer transition-all">
                                    <input
                                        type="radio"
                                        name="recomendacion_fuente"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary focus:ring-primary"
                                    />
                                    <span class="text-xs text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 3: Medical Background -->
        <div class="form-step" data-step="3">
            <div class="text-center mb-10">
                <span
                    class="text-primary font-bold text-sm uppercase tracking-wider"
                    >Paso 3 de 7</span
                >
                <h3 class="text-3xl font-bold text-slate-900 mt-2">
                    Antecedentes Médicos
                </h3>
                <p class="text-slate-500 mt-2">
                    Información clínica importante.
                </p>
            </div>

            <div class="space-y-8">
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Antecedentes personales patológicos: Seleccionar si
                        presenta alguna de las siguientes condiciones. *</label
                    >
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                        {
                            [
                                "Diarrea",
                                "Estreñimiento",
                                "Gastritis",
                                "Úlceras",
                                "Nauseas",
                                "Pirosis",
                                "Vomito",
                                "Colitis",
                                "Dentadura",
                                "Otros",
                                "Prefiero no decirlo",
                                "Ninguno",
                            ].map((opt) => (
                                <label class="flex items-center gap-2 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                    <input
                                        type="checkbox"
                                        name="antecedentes_patologicos"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary rounded"
                                    />
                                    <span class="text-xs text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Toma: *</label
                    >
                    <div class="flex flex-wrap gap-4">
                        {
                            [
                                "Laxantes",
                                "Diuréticos",
                                "Antiácidos",
                                "Analgésicos",
                                "Ninguno",
                            ].map((opt) => (
                                <label class="flex items-center gap-2 px-3 py-2 rounded-full border border-slate-100 hover:border-primary/20 cursor-pointer">
                                    <input
                                        type="checkbox"
                                        name="toma_medicamentos"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary rounded"
                                    />
                                    <span class="text-sm text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2"
                            >Enfermedades diagnosticada:</label
                        >
                        <textarea
                            name="enfermedades"
                            rows="2"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                            placeholder="Detalla si aplica..."></textarea>
                    </div>
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2"
                            >¿Tratamiento farmacológico? (Medicamentos)</label
                        >
                        <textarea
                            name="medicamentos"
                            rows="2"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                            placeholder="Nombre y dosis si los conoces..."
                        ></textarea>
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >¿Le han practicado alguna cirugía? ¿Cuál? ¿Hace cuánto
                        tiempo? *</label
                    >
                    <textarea
                        name="cirugias"
                        required
                        rows="2"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                    ></textarea>
                </div>
            </div>
        </div>

        <!-- Step 4: Family & Lifestyle -->
        <div class="form-step" data-step="4">
            <div class="text-center mb-10">
                <span
                    class="text-primary font-bold text-sm uppercase tracking-wider"
                    >Paso 4 de 7</span
                >
                <h3 class="text-3xl font-bold text-slate-900 mt-2">
                    Familia y Hábitos
                </h3>
                <p class="text-slate-500 mt-2">Entorno y rutinas diarias.</p>
            </div>

            <div class="space-y-8">
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >¿Alguien de tu familia presenta alguna enfermedad?
                        (Madre, padre, hermanos, tios) *</label
                    >
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                        {
                            [
                                "Diabetes",
                                "Hipertensión",
                                "Cáncer",
                                "Cardiopatías",
                                "Obesidad",
                                "Colesterol",
                                "Triglicéridos",
                                "Otra",
                                "Ninguna",
                            ].map((opt) => (
                                <label class="flex items-center gap-2 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                    <input
                                        type="checkbox"
                                        name="antecedentes_familiares"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary rounded"
                                    />
                                    <span class="text-xs text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-3"
                            >¿Bebidas alcohólicas? *</label
                        >
                        <div class="space-y-2">
                            {
                                [
                                    "Si",
                                    "No",
                                    "Lo deje",
                                    "Social (1 vez a la semana)",
                                    "Frecuente (2 veces a la semana)",
                                    "Muy frencuente (mas de 3 veces a la semana)",
                                ].map((opt) => (
                                    <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                        <input
                                            type="radio"
                                            name="alcohol"
                                            value={opt}
                                            required
                                            class="w-4 h-4 text-primary"
                                        />
                                        <span class="text-xs text-slate-600">
                                            {opt}
                                        </span>
                                    </label>
                                ))
                            }
                        </div>
                    </div>
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-3"
                            >¿Cigarros? *</label
                        >
                        <div class="space-y-2">
                            {
                                [
                                    "Si",
                                    "No",
                                    "Lo deje",
                                    "Social (1 vez a la semana)",
                                    "Frecuente (1 vez al dia)",
                                    "Muy frencuente (mas de 2 veces al dia)",
                                ].map((opt) => (
                                    <label class="flex items-center gap-3 p-2 rounded-lg border border-slate-50 hover:bg-slate-50 cursor-pointer">
                                        <input
                                            type="radio"
                                            name="tabaco"
                                            value={opt}
                                            required
                                            class="w-4 h-4 text-primary"
                                        />
                                        <span class="text-xs text-slate-600">
                                            {opt}
                                        </span>
                                    </label>
                                ))
                            }
                        </div>
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Horas de sueño al día: *</label
                    >
                    <div class="flex flex-wrap gap-3">
                        {
                            [
                                "Menos de 5 horas",
                                "6 horas",
                                "7 a 8 horas",
                                "Màs de 8 horas",
                                "Màs de 10 horas",
                            ].map((opt) => (
                                <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-primary/20 cursor-pointer transition-all">
                                    <input
                                        type="radio"
                                        name="sueno"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary"
                                    />
                                    <span class="text-sm text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 5: Physical Activity & Work -->
        <div class="form-step" data-step="5">
            <div class="text-center mb-10">
                <span
                    class="text-primary font-bold text-sm uppercase tracking-wider"
                    >Paso 5 de 7</span
                >
                <h3 class="text-3xl font-bold text-slate-900 mt-2">
                    Actividad y Trabajo
                </h3>
                <p class="text-slate-500 mt-2">Tu movimiento y occupation.</p>
            </div>

            <div class="space-y-8">
                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-3"
                        >Actividad física: ¿Realiza actividad física? *</label
                    >
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        {
                            [
                                "No",
                                "1 vez a la semana",
                                "De lunes a viernes",
                                "De lunes a domingo",
                                "3 veces a la semana",
                            ].map((opt) => (
                                <label class="flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:bg-slate-50 cursor-pointer">
                                    <input
                                        type="radio"
                                        name="hace_ejercicio"
                                        value={opt}
                                        required
                                        class="w-4 h-4 text-primary"
                                    />
                                    <span class="text-sm text-slate-600">
                                        {opt}
                                    </span>
                                </label>
                            ))
                        }
                        <div
                            class="flex items-center gap-3 p-2 rounded-xl border border-slate-100 italic"
                        >
                            <span class="text-xs text-slate-400"
                                >Si es otra, especifica debajo</span
                            >
                        </div>
                    </div>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Actividad física: ¿Qué actividad física se hace?
                        ¿Cuánto tiempo cada sesión? ¿Desde hace cuánto tiempo?</label
                    >
                    <input
                        type="text"
                        name="ejercicio_detalles"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all"
                        placeholder="Ej. Natación, 45 min, 6 meses"
                    />
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2"
                            >Profesión / Ocupación: ¿A que se dedica?</label
                        >
                        <textarea
                            name="profesion"
                            rows="2"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        ></textarea>
                    </div>
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2"
                            >Profesión / Ocupación: ¿Su actividad es sentado
                            (a), parado (a), caminando, etc.? ¿Cuál es su
                            horario laboral?</label
                        >
                        <textarea
                            name="tipo_actividad_horario"
                            rows="2"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-primary outline-none transition-all resize-none"
                        ></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 6: Nutritional Habits 1 -->
