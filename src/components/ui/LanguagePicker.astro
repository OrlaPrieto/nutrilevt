---
import { languages } from '../../i18n/ui';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---
<div class="flex items-center gap-1.5 bg-slate-100/50 p-1 rounded-full border border-slate-200/50 backdrop-blur-sm">
  {Object.entries(languages).map(([code, label]) => (
    <a 
      href={code === 'es' ? '/' : `/${code}/`}
      class={`px-3 py-1 text-[10px] font-bold tracking-wider rounded-full transition-all duration-300 ${
        lang === code 
          ? 'bg-white text-primary shadow-sm ring-1 ring-slate-200' 
          : 'text-slate-500 hover:text-primary hover:bg-white/50'
      }`}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>
