---
import Layout from "../layouts/Layout.astro";
import FloatingCTA from "../components/ui/FloatingCTA.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langPath = lang === "es" ? "" : `/${lang}`;
---

<Layout title={`${t('thanks.title')} | Nutrilev`}>
    <div
        class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-6 relative overflow-hidden"
    >
        <!-- Background Decorators -->
        <div
            class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-pink-100/50 rounded-full blur-3xl pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-[30rem] h-[30rem] bg-rose-50/50 rounded-full blur-[100px] pointer-events-none"
        >
        </div>

        <div
            class="bg-white rounded-[2.5rem] p-10 md:p-14 shadow-2xl shadow-pink-100 border border-pink-50 max-w-2xl w-full text-center relative z-10 animate-fade-in-up"
        >
            <div
                class="w-28 h-28 bg-gradient-to-br from-primary to-accent rounded-full flex items-center justify-center text-5xl mb-8 mx-auto shadow-lg shadow-primary/30 text-white animate-bounce-slow"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-14 w-14"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"></path>
                </svg>
            </div>

            <h1
                class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tight"
            >
                {t('thanks.title')}
            </h1>

            <p
                class="text-xl text-slate-600 mb-10 leading-relaxed max-w-lg mx-auto"
            >
                {t('thanks.message')}
            </p>

            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4"
            >
                <a
                    id="whatsapp-schedule-btn"
                    href={`https://wa.me/526143958598?text=${encodeURIComponent(t('thanks.whatsappMessage'))}`}
                    target="_blank"
                    class="bg-[#25D366] text-white px-8 py-4 rounded-2xl font-bold shadow-xl shadow-[#25D366]/20 hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-3 w-full sm:w-auto text-lg"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 16 16"
                    >
                        <path
                            d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
                        ></path>
                    </svg>
                    {t('thanks.whatsapp')}
                </a>
                <a
                    href={`${langPath}/`}
                    class="px-8 py-4 rounded-2xl font-bold text-slate-500 hover:bg-slate-100 transition-all text-lg w-full sm:w-auto"
                >
                    {t('thanks.back')}
                </a>
            </div>
        </div>
    </div>
    <FloatingCTA />
</Layout>

<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes bounce-slow {
        0%,
        100% {
            transform: translateY(-5%);
            animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
        }
        50% {
            transform: translateY(0);
            animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    .animate-bounce-slow {
        animation: bounce-slow 3s infinite;
    }
</style>

<script>
    // En caso de que se haya pasado el nombre por URL para personalizar el mensaje
    document.addEventListener("astro:page-load", () => {
        const urlParams = new URLSearchParams(window.location.search);
        const nameParam = urlParams.get("name");
        const whatsappBtn = document.getElementById(
            "whatsapp-schedule-btn"
        ) as HTMLAnchorElement;

        if (whatsappBtn && nameParam) {
            const encodedName = encodeURIComponent(nameParam);
            const message = t('thanks.whatsappMessageWithName').replace('{name}', nameParam);
            whatsappBtn.href = `https://wa.me/526143958598?text=${encodeURIComponent(message)}`;
        }
    });
</script>
