---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Equipment from "../components/Equipment.astro";
import Services from "../components/Services.astro";
import ConsultationModes from "../components/ConsultationModes.astro";
import Testimonials from "../components/Testimonials.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import experienceImg from "../assets/experience-nutrilev.jpg";
import WhatsAppIcon from "../components/icons/WhatsAppIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import FacebookIcon from "../components/icons/FacebookIcon.astro";
---

<Layout
  title="Especialista en Nutrición Clínica"
  description="Atención nutricional especializada con enfoque clínico y humano en Chihuahua. Transforma tu salud con planes personalizados y tecnología InBody 270."
>
  <Navbar />
  <main>
    <Hero />
    <About />
    <section class="py-24 bg-bg-base">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:flex lg:items-center gap-16">
          <div class="lg:w-1/2 mb-12 lg:mb-0">
            <span
              class="text-accent font-semibold tracking-wider uppercase text-sm"
              >Experiencia Nutrilev</span
            >
            <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 mt-4 mb-8">
              Tu camino hacia una <span class="text-primary">mejor salud</span> empieza
              aquí.
            </h2>
            <p class="text-lg text-slate-600 leading-relaxed mb-6">
              Nuestras consultas están diseñadas para brindarte un espacio de
              confianza y profesionalismo. Analizamos tu historial, resolvemos
              tus dudas y trazamos juntos el plan que te llevará a tus
              objetivos.
            </p>
            <div class="flex items-center gap-4 text-primary font-bold">
              <span class="text-2xl">✨</span>
              <p>Atención 100% enfocada en tus necesidades.</p>
            </div>
          </div>
          <div class="lg:w-1/2">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl">
              <Image
                src={experienceImg}
                alt="Experiencia Nutrilev - Velvet De la Cruz"
                class="w-full h-[400px] object-cover"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <Equipment />
    <Services />
    <ConsultationModes />
    <Testimonials />
    <section
      id="booking"
      class="py-24 bg-gradient-to-tr from-accent to-primary text-white"
    >
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl lg:text-6xl font-bold mb-8 italic">
          ¿Listo para comenzar tu transformación?
        </h2>
        <p class="text-xl mb-4 opacity-90">
          Inicia tu proceso hoy mismo. Completa nuestro formulario de contacto
          para agendar tu cita y realizar el llenado de tu historial clínico.
        </p>
        <div class="flex flex-col items-center gap-2 mb-12">
          <p
            class="text-lg opacity-80 italic underline decoration-pink-300 underline-offset-4 font-light"
          >
            Este es el primer paso para gendar tu cita.
          </p>
          <div
            class="inline-flex items-center gap-2 bg-white/10 px-4 py-1 rounded-full text-sm border border-white/20"
          >
            <span class="text-pink-200">🕒</span>
            <span>Horarios: Lun-Vie 9:00-18:30 | Sáb 8:00-17:00</span>
          </div>
        </div>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-6"
        >
          <a
            href="https://forms.gle/fTbGLx5JtzZ38Tot7"
            target="_blank"
            class="bg-white text-primary px-12 py-5 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-2xl flex items-center gap-2"
          >
            <span>Ir al formulario de contacto</span>
          </a>
        </div>
        <div
          class="mt-16 flex justify-center gap-10 border-t border-white/20 pt-10"
        >
          <a
            href="https://wa.me/526143958598"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-green-400"
            aria-label="WhatsApp"
          >
            <WhatsAppIcon class="w-10 h-10" />
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=100064033451986"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-blue-500"
            aria-label="Facebook"
          >
            <FacebookIcon class="w-10 h-10" />
          </a>
          <a
            href="https://www.instagram.com/nutrilev_especializada"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-pink-400"
            aria-label="Instagram"
          >
            <InstagramIcon class="w-10 h-10" />
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
