---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/sections/Navbar.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Equipment from "../components/sections/Equipment.astro";
import Services from "../components/sections/Services.astro";
import ConsultationModes from "../components/sections/ConsultationModes.astro";
import TestimonialsImproved from "../components/sections/TestimonialsImproved.astro";
import Footer from "../components/sections/Footer.astro";
import WhatsAppFloat from "../components/ui/WhatsAppFloat.astro";
import FAQ from "../components/sections/FAQ.astro";
import Pricing from "../components/sections/Pricing.astro";
import BeforeAfter from "../components/sections/BeforeAfter.astro";
import HistorySection from "../components/sections/HistorySection.astro";
import { Image } from "astro:assets";
import experienceImg from "../assets/experience-nutrilev.jpg";
import WhatsAppIcon from "../components/ui/icons/WhatsAppIcon.astro";
import InstagramIcon from "../components/ui/icons/InstagramIcon.astro";
import FacebookIcon from "../components/ui/icons/FacebookIcon.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langPath = lang === "es" ? "" : `/${lang}`;
---

<Layout
  title={t('site.title')}
  description={t('site.description')}
>
  <Navbar />
  <WhatsAppFloat />
  <main>
    <Hero />
    <About />
    <section class="py-16 lg:py-20 bg-slate-50 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:flex lg:items-center gap-16">
          <div class="lg:w-1/2 mb-12 lg:mb-0">
            <span
              class="text-primary font-semibold tracking-wider uppercase text-sm"
              >{t('experience.badge')}</span
            >
            <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 mt-4 mb-8">
              {t('experience.title').split(lang === 'es' ? 'mejor salud' : 'better health').map((part, i, arr) => (
                <>
                  {part}
                  {i < arr.length - 1 && (
                    <span class="italic bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">{lang === 'es' ? 'mejor salud' : 'better health'}</span>
                  )}
                </>
              ))}
            </h2>
            <p class="text-lg text-slate-600 leading-relaxed mb-6">
              {t('experience.p1')}
            </p>
            <div class="flex items-center gap-4 text-primary font-bold">
              <span class="text-2xl">✨</span>
              <p>{t('experience.feature1')}</p>
            </div>
          </div>
          <div class="lg:w-1/2">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl">
              <Image
                src={experienceImg}
                alt={t('experience.imageAlt')}
                class="w-full h-[400px] object-cover"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <Equipment />
    <Services />
    <ConsultationModes />
    <!-- <Pricing /> -->
    <!-- <BeforeAfter /> -->
    <TestimonialsImproved />
    <FAQ />
    <section
      id="booking"
      class="py-16 lg:py-20 bg-gradient-to-tr from-accent to-primary text-white overflow-hidden"
    >
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl lg:text-6xl font-bold mb-8 italic">
          {t('booking.title')}
        </h2>
        <p class="text-xl mb-4 opacity-90">
          {t('booking.subtitle')}
        </p>
        <div class="flex flex-col items-center gap-2 mb-12">
          <p
            class="text-lg opacity-80 italic underline decoration-pink-300 underline-offset-4 font-light"
          >
            {t('booking.note1')}
          </p>
          <div
            class="inline-flex items-center gap-2 bg-white/10 px-4 py-1 rounded-full text-sm border border-white/20"
          >
            <span class="text-pink-200">🕒</span>
            <span>{t('booking.hours')}</span>
          </div>
        </div>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-6"
        >
          <a
            href={`${langPath}/#clinical-history`}
            class="bg-white text-primary px-12 py-5 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-2xl flex items-center gap-2"
          >
            <span>{t('booking.cta')}</span>
          </a>
        </div>
        <div
          class="mt-16 flex justify-center gap-10 border-t border-white/20 pt-10"
        >
          <a
            href="https://wa.me/526143958598"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-accent"
            aria-label="WhatsApp"
          >
            <WhatsAppIcon class="w-10 h-10" />
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=100064033451986"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-blue-500"
            aria-label="Facebook"
          >
            <FacebookIcon class="w-10 h-10" />
          </a>
          <a
            href="https://www.instagram.com/nutrilev_especializada"
            target="_blank"
            class="hover:scale-110 transition-transform hover:text-accent"
            aria-label="Instagram"
          >
            <InstagramIcon class="w-10 h-10" />
          </a>
        </div>
      </div>
    </section>
    <HistorySection />
  </main>
  <Footer />
</Layout>

<!-- Scroll animations are handled by the fade-in-section system in Layout.astro -->
